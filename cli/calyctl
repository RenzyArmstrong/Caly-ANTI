EPILOG = """\
examples:
  calyctl status                      what is running, in what mode
  calyctl stats --watch               live dashboard (curses, or plain text)
  calyctl stats --json                every counter, machine readable
  calyctl top -n 20                   noisiest sources
  calyctl ban 203.0.113.9 --ttl 1h    ban one address for an hour
  calyctl ban 198.51.100.0/24 --yes   ban a prefix (goes to the blocklist)
  calyctl allow 203.0.113.0/24        operator escape hatch, checked first
  calyctl list bans                   what is banned and for how long
  calyctl import feed.txt --block     load a threat feed
  calyctl export > /tmp/caly.conf     dump lists as config directives
  calyctl mode under-attack           tighten every bucket, engage synproxy
  calyctl port limit tcp/443 --rate 50k --burst 100k
  calyctl conntrack --proto tcp       established flows
  calyctl doctor                      why is this not working

safety:
  Destructive actions confirm unless --yes. Banning or blocking a prefix that
  covers the address you are connected from needs --force. Management ports
  (TCP/22 always among them) and the allowlist are checked before every drop
  rule in every mode, so an SSH session on a management port survives even a
  ban of its own source address.

exit codes:
  0 ok   1 error   2 usage   3 refused (safety)   4 no backend   5 diagnostics
"""


def add_common(parser):
    """Shared flags. SUPPRESS keeps a subparser default from clobbering a
    value given before the subcommand name."""
    group = parser.add_argument_group("common options")
    group.add_argument("--socket", metavar="PATH", default=argparse.SUPPRESS,
                       help="daemon control socket (default: autodetect)")
    group.add_argument("--pin-dir", metavar="DIR", default=argparse.SUPPRESS,
                       help="pinned map directory (default: %s)" % CALY_PIN_DIR)
    group.add_argument("--direct", action="store_true",
                       default=argparse.SUPPRESS,
                       help="bypass the daemon and use bpftool on the pinned "
                            "maps (needs root)")
    group.add_argument("--daemon-only", action="store_true",
                       default=argparse.SUPPRESS,
                       help="never fall back to direct map access")
    group.add_argument("--timeout", type=float, metavar="SEC",
                       default=argparse.SUPPRESS,
                       help="control socket timeout (default 5)")
    group.add_argument("--json", action="store_true",
                       default=argparse.SUPPRESS,
                       help="machine-readable output")
    group.add_argument("--color", "--colour", dest="color",
                       choices=("auto", "always", "never"),
                       default=argparse.SUPPRESS, help="colour output")
    group.add_argument("-y", "--yes", action="store_true",
                       default=argparse.SUPPRESS,
                       help="assume yes; required for destructive actions "
                            "without a terminal")
    group.add_argument("--force", action="store_true",
                       default=argparse.SUPPRESS,
                       help="override the lockout guard (banning your own "
                            "source address)")
    group.add_argument("-v", "--verbose", action="count",
                       default=argparse.SUPPRESS, help="more detail; twice "
                                                       "traces every backend "
                                                       "call")
    return parser


def build_parser():
    parser = argparse.ArgumentParser(
        prog="calyctl",
        description="Caly Anti operator CLI and live dashboard.",
        epilog=EPILOG,
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser.add_argument("--version", action="version",
                        version="calyctl " + CALYCTL_VERSION)
    # Real defaults live on the top-level parser only.
    parser.set_defaults(socket=None, pin_dir=None, direct=False,
                        daemon_only=False, timeout=5.0, json=False,
                        color="auto", yes=False, force=False, verbose=0)
    add_common(parser)

    common = argparse.ArgumentParser(add_help=False)
    add_common(common)

    subs = parser.add_subparsers(dest="cmd", metavar="<command>")

    p = subs.add_parser("status", parents=[common],
                        help="operating mode, capabilities and throughput")
    p.add_argument("--fast", action="store_true",
                   help="skip the 0.5s rate sample and the map counts")
    p.set_defaults(func=cmd_status)

    p = subs.add_parser("stats", parents=[common],
                        help="packet and byte counters per reason")
    p.add_argument("-w", "--watch", action="store_true",
                   help="live dashboard instead of a one-shot dump")
    p.add_argument("-a", "--all", action="store_true",
                   help="include counters that are still zero")
    p.add_argument("--sort", choices=("index", "value"), default="index",
                   help="order within each section (default index)")
    p.add_argument("--interval", type=float, default=1.0, metavar="SEC",
                   help="watch sampling interval (default 1.0)")
    p.add_argument("--plain", action="store_true",
                   help="force the plain-text watcher, never curses")
    p.add_argument("--ascii", action="store_true",
                   help="ASCII sparklines even where UTF-8 is available")
    p.add_argument("--top", type=int, default=8, metavar="N",
                   help="talkers to show in the dashboard (default 8)")
    p.set_defaults(func=cmd_stats)

    p = subs.add_parser("dashboard", parents=[common], aliases=[],
                        help="alias for `stats --watch`")
    p.add_argument("--interval", type=float, default=1.0, metavar="SEC")
    p.add_argument("--plain", action="store_true")
    p.add_argument("--ascii", action="store_true")
    p.add_argument("--top", type=int, default=8, metavar="N")
    p.set_defaults(func=cmd_dashboard)

    p = subs.add_parser("top", parents=[common], help="noisiest sources")
    p.add_argument("-n", "--n", "--count", dest="n", type=int, default=20,
                   metavar="N", help="rows to show (default 20)")
    p.add_argument("--family", choices=("4", "6"), default=None,
                   help="restrict to IPv4 or IPv6")
    p.add_argument("--sort", choices=("packets", "bytes", "drops",
                                      "drop_bytes"),
                   default="packets", help="sort key (default packets)")
    p.set_defaults(func=cmd_top)

    p = subs.add_parser("ban", parents=[common],
                        help="dynamically ban an address or prefix")
    p.add_argument("cidr", nargs="+", help="address or CIDR")
    p.add_argument("--ttl", metavar="DUR",
                   help="ban duration (10m, 4h, 2d; 0 means permanent). "
                        "Default: ban_ttl_base from the running config")
    p.add_argument("--permanent", action="store_true",
                   help="never expire this ban")
    p.add_argument("--reason", metavar="NAME",
                   help="stat_reason to record, e.g. drop_portscan")
    p.set_defaults(func=cmd_ban)

    p = subs.add_parser("unban", parents=[common], help="remove a ban")
    p.add_argument("cidr", nargs="+")
    p.set_defaults(func=cmd_unban)

    p = subs.add_parser("allow", parents=[common],
                        help="add to the allowlist (unconditional pass)")
    p.add_argument("cidr", nargs="+")
    p.add_argument("--tag", type=int, default=0, metavar="N",
                   help="operator tag stored in rule_meta.tag")
    p.add_argument("--no-bypass-rate", action="store_true",
                   help="keep the per-source token buckets for this prefix")
    p.set_defaults(func=cmd_allow)

    p = subs.add_parser("unallow", parents=[common],
                        help="remove from the allowlist")
    p.add_argument("cidr", nargs="+")
    p.set_defaults(func=cmd_unallow)

    p = subs.add_parser("block", parents=[common],
                        help="add to the static blocklist")
    p.add_argument("cidr", nargs="+")
    p.add_argument("--tag", type=int, default=0, metavar="N")
    p.set_defaults(func=cmd_block)

    p = subs.add_parser("unblock", parents=[common],
                        help="remove from the static blocklist")
    p.add_argument("cidr", nargs="+")
    p.set_defaults(func=cmd_unblock)

    p = subs.add_parser("list", parents=[common], help="show a list")
    p.add_argument("what", choices=("allow", "block", "local", "bans", "ban"))
    p.add_argument("--limit", type=int, default=0, metavar="N",
                   help="stop after N entries (0 = all)")
    p.set_defaults(func=cmd_list)

    p = subs.add_parser("import", parents=[common],
                        help="load prefixes from a file")
    p.add_argument("file")
    group = p.add_mutually_exclusive_group()
    group.add_argument("--allow", action="store_true",
                       help="treat bare prefixes as allowlist entries")
    group.add_argument("--block", action="store_true",
                       help="treat bare prefixes as blocklist entries")
    group.add_argument("--local", action="store_true",
                       help="treat bare prefixes as local (anti-spoof) "
                            "prefixes")
    p.add_argument("--tag", type=int, default=0, metavar="N",
                   help="tag every imported entry (feed id)")
    p.add_argument("--no-bypass-rate", action="store_true")
    p.set_defaults(func=cmd_import)

    p = subs.add_parser("export", parents=[common],
                        help="dump lists as configuration directives")
    p.add_argument("what", nargs="?", default="all",
                   choices=("all", "allow", "block", "local", "bans", "ports",
                            "config"))
    p.add_argument("-o", "--output", metavar="FILE",
                   help="write here instead of stdout")
    p.set_defaults(func=cmd_export)

    p = subs.add_parser("mode", parents=[common], help="change operating mode")
    p.add_argument("mode", help="normal | elevated | under-attack | "
                                "lockdown | monitor")
    p.set_defaults(func=cmd_mode)

    p = subs.add_parser("port", parents=[common], help="per-port policy")
    p.add_argument("action", choices=("open", "close", "limit"))
    p.add_argument("portspec", metavar="PROTO/PORT",
                   help="tcp/443, udp/53, tcp/8000-8100")
    p.add_argument("--rate", metavar="PPS",
                   help="packets/sec for limit (20k, 1.5m)")
    p.add_argument("--burst", metavar="PKTS", help="bucket depth for limit")
    p.set_defaults(func=cmd_port)

    p = subs.add_parser("conntrack", parents=[common],
                        help="established flows")
    p.add_argument("--limit", type=int, default=50, metavar="N",
                   help="rows to show (default 50, 0 = all)")
    p.add_argument("--proto", help="tcp, udp, icmp, or a protocol number")
    p.add_argument("--src", metavar="CIDR", help="restrict to a source prefix")
    p.set_defaults(func=cmd_conntrack)

    p = subs.add_parser("reload", parents=[common],
                        help="re-read the configuration file")
    p.set_defaults(func=cmd_reload)

    p = subs.add_parser("test", parents=[common],
                        help="self diagnostics: ABI layout, arithmetic, "
                             "invariants")
    p.set_defaults(func=cmd_test)

    p = subs.add_parser("doctor", parents=[common],
                        help="diagnose the environment: kernel, BTF, bpffs, "
                             "driver, sysctl drift, conflicts")
    p.set_defaults(func=cmd_doctor)

    p = subs.add_parser("version", parents=[common],
                        help="versions of everything that matters")
    p.set_defaults(func=cmd_version)

    return parser


def main(argv=None):
    if hasattr(signal, "SIGPIPE"):
        try:
            signal.signal(signal.SIGPIPE, signal.SIG_DFL)
        except (ValueError, OSError):
            pass

    parser = build_parser()
    opts = parser.parse_args(argv)
    if not getattr(opts, "cmd", None) or not hasattr(opts, "func"):
        parser.print_help()
        return EXIT_USAGE

    opts.pal = Palette(want_colour(opts.color, sys.stdout))
    if opts.json:
        opts.pal = Palette(False)

    session = Session(opts)
    try:
        return opts.func(opts, session)
    except CalyError as exc:
        sys.stderr.write("calyctl: {0}\n".format(exc.message))
        return exc.code
    except KeyboardInterrupt:
        sys.stderr.write("\ninterrupted\n")
        return 130
    except BrokenPipeError:
        try:
            os.close(sys.stdout.fileno())
        except Exception:
            pass
        return EXIT_OK
    except OSError as exc:
        sys.stderr.write("calyctl: {0}\n".format(exc))
        return EXIT_ERROR
    finally:
        session.close()
        try:
            sys.stdout.flush()
        except Exception:
            pass


if __name__ == "__main__":
    sys.exit(main())



