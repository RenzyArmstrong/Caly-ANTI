def cmd_ban(opts, session):
    nets = [parse_cidr(c) for c in opts.cidr]
    ttl_ns = parse_duration(opts.ttl) if opts.ttl else None
    permanent = bool(getattr(opts, "permanent", False)) or ttl_ns == 0
    if ttl_ns is None:
        try:
            ttl_ns = int(session.config().get("ban_ttl_base_ns") or 0) or \
                600 * NSEC_PER_SEC
        except CalyError:
            ttl_ns = 600 * NSEC_PER_SEC
    reason = opts.reason
    reason_idx = STAT_BAN_ADDED
    if reason and reason in STAT_INDEX:
        reason_idx = STAT_INDEX[reason]

    lockout_guard(nets, opts, "ban", _mgmt_ports(session), opts.pal)
    what = ", ".join(str(n) for n in nets)
    ttl_text = "permanently" if permanent else "for " + human_ns(ttl_ns)
    if not confirm(opts, "Ban {0} {1}?".format(what, ttl_text)):
        print("aborted")
        return EXIT_REFUSED
    changed = 0
    notes = []
    for net in nets:
        result = session.call("add_ban", net, ttl_ns, reason_idx, permanent)
        changed += int(result.get("changed", 1) or 0)
        if result.get("note"):
            notes.append("{0}: {1}".format(net, result["note"]))
    if opts.json:
        emit_json({"banned": [str(n) for n in nets], "changed": changed,
                   "ttl_ns": 0 if permanent else ttl_ns, "notes": notes})
        return EXIT_OK
    print("banned {0} ({1} entr{2} written) {3}".format(
        what, changed, "y" if changed == 1 else "ies", ttl_text))
    for note in notes:
        print("  note: " + note)
    return EXIT_OK


def cmd_unban(opts, session):
    nets = [parse_cidr(c) for c in opts.cidr]
    if not confirm(opts, "Remove the ban on {0}?".format(
            ", ".join(str(n) for n in nets)), default=True):
        print("aborted")
