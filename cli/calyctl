_DIRECTIVE_RE = re.compile(r"^\s*(allow|block|local)\s*=\s*(.*)$", re.I)


def parse_list_file(path):
    """Read a prefix list. Returns (entries, bad) where entries is a list of
    (kind_or_None, network)."""
    entries, bad = [], []
    try:
        handle = open(path, "r")
    except IOError as exc:
        raise CalyError("cannot read {0}: {1}".format(path, exc.strerror))
    try:
        for lineno, line in enumerate(handle, 1):
            line = line.split("#", 1)[0].split(";", 1)[0].strip()
            if not line or line.startswith("["):
                continue
            kind = None
            match = _DIRECTIVE_RE.match(line)
            if match:
                kind = match.group(1).lower()
                line = match.group(2).strip()
            elif "=" in line:
                line = line.split("=", 1)[1].strip()
            for token in re.split(r"[,\s]+", line):
                if not token:
                    continue
                try:
                    entries.append((kind, parse_cidr(token)))
                except CalyError:
                    bad.append((lineno, token))
    finally:
        handle.close()
    return entries, bad


def cmd_import(opts, session):
    entries, bad = parse_list_file(opts.file)
    default_kind = None
    if opts.allow:
        default_kind = "allow"
    elif opts.block:
        default_kind = "block"
    elif opts.local:
        default_kind = "local"
    untyped = [net for kind, net in entries if kind is None]
    if untyped and default_kind is None:
        raise CalyError(
            "{0} contains {1} bare prefixes and no allow=/block= directives; "
            "say --allow, --block or --local".format(opts.file, len(untyped)))
    buckets = {"allow": [], "block": [], "local": []}
    for kind, net in entries:
        buckets[kind or default_kind].append(net)
    total = sum(len(v) for v in buckets.values())
    if not total:
        raise CalyError("{0} contained no usable prefixes".format(opts.file))

    summary = ", ".join("{0} {1}".format(len(v), k)
                        for k, v in sorted(buckets.items()) if v)
    if buckets["block"]:
        lockout_guard(buckets["block"], opts, "block",
                      _mgmt_ports(session), opts.pal)
    if not confirm(opts, "Import {0} from {1}?".format(summary, opts.file)):
        print("aborted")
        return EXIT_REFUSED

    changed = 0
    for kind, nets in sorted(buckets.items()):
        if not nets:
            continue
        direct = session.direct()
        if direct is not None and session.daemon() is None and \
                hasattr(direct, "add_rules_bulk"):
            changed += int(direct.add_rules_bulk(
                kind, nets, opts.tag,
                not getattr(opts, "no_bypass_rate", False))
                .get("changed", 0) or 0)
        else:
            for net in nets:
                result = session.call("add_rule", kind, net, opts.tag,
                                      not getattr(opts, "no_bypass_rate",
                                                  False))
                changed += int(result.get("changed", 1) or 0)
    if opts.json:
        emit_json({"file": opts.file, "imported": changed,
                   "rejected": [{"line": l, "text": t} for l, t in bad]})
        return EXIT_OK
    print("imported {0} prefixes ({1})".format(changed, summary))
    if bad:
        print("  {0} unparsable line(s) skipped:".format(len(bad)))
        for lineno, text in bad[:10]:
            print("    line {0}: {1!r}".format(lineno, text))
        if len(bad) > 10:
            print("    ... and {0} more".format(len(bad) - 10))
    return EXIT_OK


def cmd_export(opts, session):
    what = opts.what
    data = {}
    wanted = ("allow", "block", "local", "bans", "ports", "config") \
        if what == "all" else (what,)
    if "allow" in wanted:
        data["allow"] = session.call("list_entries", "allow", limit=0)
    if "block" in wanted:
        data["block"] = session.call("list_entries", "block", limit=0)
    if "local" in wanted:
        data["local"] = session.call("list_entries", "local", limit=0)
    if "bans" in wanted:
        data["bans"] = session.call("list_entries", "bans", limit=0)
    if "ports" in wanted:
        try:
            data["ports"] = {"tcp": session.call("port_rules", "tcp"),
                             "udp": session.call("port_rules", "udp")}
        except CalyError:
            data["ports"] = {"tcp": [], "udp": []}
    if "config" in wanted:
        try:
            data["config"] = session.config()
        except CalyError:
            data["config"] = None

    out = sys.stdout
    handle = None
    if opts.output and opts.output != "-":
        try:
            handle = open(opts.output, "w")
        except IOError as exc:
            raise CalyError("cannot write {0}: {1}".format(
                opts.output, exc.strerror))
        out = handle
    try:
        if opts.json:
            json.dump(data, out, indent=2, sort_keys=True, default=str)
            out.write("\n")
            return EXIT_OK
        now_mono, now_wall = monotonic_ns(), time.time()
        out.write("# Caly Anti export - {0}\n".format(
            time.strftime("%Y-%m-%d %H:%M:%S %z")))
        out.write("# Generated by calyctl {0}. Paste the allow/block/local\n"
                  "# and *_port lines into {1}; bans are runtime state and\n"
                  "# are listed as comments only.\n\n".format(
                      CALYCTL_VERSION, CALY_CONF_PATH))
        cfg = data.get("config")
        if isinstance(cfg, dict):
            out.write("# mode = {0}\n".format(
                MODE_NAMES.get(int(cfg.get("mode", 0)), "?")))
            out.write("# mgmt_tcp_ports = {0}\n\n".format(
                ", ".join(str(p) for p in cfg.get("mgmt_tcp_ports", []))))
        for kind, section in (("allow", "[allowlist]"),
                              ("block", "[blocklist]"),
                              ("local", "[local]")):
            rows = data.get(kind)
            if rows is None:
                continue
            out.write("{0}\n".format(section))
            for row in sorted(rows, key=lambda r: str(r.get("cidr"))):
                suffix = ""
                if row.get("tag"):
                    suffix = "    # tag {0}".format(row["tag"])
                out.write("{0} = {1}{2}\n".format(kind, row.get("cidr", "?"),
                                                  suffix))
            out.write("\n")
        ports = data.get("ports")
        if ports:
            out.write("[ports]\n")
            for proto in ("tcp", "udp"):
                for rule in ports.get(proto, []):
                    mode = PORT_MODE_NAMES.get(int(rule.get("mode", 0)), "?")
                    line = "{0}_port = {1} {2}".format(proto, rule["port"],
                                                       mode)
                    if mode == "ratelimit":
                        line += " rate={0} burst={1}".format(
                            rule.get("rate", 0), rule.get("burst", 0))
                    flags = flags_str(rule.get("flags", 0), PORT_FLAG_BITS, "")
                    if flags:
                        line += "    # {0}".format(flags)
                    out.write(line + "\n")
            out.write("\n")
        bans = data.get("bans")
        if bans is not None:
            out.write("# --- active bans (runtime state, not configuration) "
                      "---\n")
            for row in bans:
                expiry = int(row.get("expiry_ns", 0) or 0)
                left = "permanent" if not expiry else human_ns(
                    max(0, expiry - now_mono))
                out.write("# ban = {0}  expires_in={1}  reason={2}  "
                          "offences={3}\n".format(
                              row.get("cidr", "?"), left,
                              reason_name(row.get("reason", 0)),
                              row.get("offences", 0)))
    finally:
        if handle is not None:
            handle.close()
            if not opts.json:
                print("wrote {0}".format(opts.output))
    return EXIT_OK


