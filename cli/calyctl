class CalyError(Exception):
    """Any operator-visible failure. Carries an exit code."""

    def __init__(self, message, code=EXIT_ERROR):
        Exception.__init__(self, message)
        self.message = message
        self.code = code


class BackendUnavailable(CalyError):
    def __init__(self, message):
        CalyError.__init__(self, message, EXIT_NO_BACKEND)


class NotSupported(CalyError):
    """The selected backend cannot perform this operation at all."""


