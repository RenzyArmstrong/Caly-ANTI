def human_count(n, width=None):
    """1234567 -> '1.23M'. Never wider than 7 characters."""
    try:
        n = float(n)
    except (TypeError, ValueError):
        return "-"
    neg = n < 0
    n = abs(n)
    for suffix, div in (("T", 1e12), ("G", 1e9), ("M", 1e6), ("k", 1e3)):
        if n >= div:
            v = n / div
            if v >= 100:
                s = "{0:.0f}{1}".format(v, suffix)
            elif v >= 10:
                s = "{0:.1f}{1}".format(v, suffix)
            else:
                s = "{0:.2f}{1}".format(v, suffix)
            break
    else:
        s = "{0:.0f}".format(n)
    if neg:
        s = "-" + s
    if width:
        s = s.rjust(width)
    return s


def human_bytes(n):
    try:
        n = float(n)
    except (TypeError, ValueError):
        return "-"
    for suffix, div in (("TiB", 1 << 40), ("GiB", 1 << 30),
                        ("MiB", 1 << 20), ("KiB", 1 << 10)):
        if n >= div:
            return "{0:.2f} {1}".format(n / div, suffix)
    return "{0:.0f} B".format(n)


def human_bps(bytes_per_sec):
    """Byte rate, shown as bytes/s. Bit/s is added by callers that want it."""
    try:
        v = float(bytes_per_sec)
    except (TypeError, ValueError):
        return "-"
    for suffix, div in (("TB/s", 1e12), ("GB/s", 1e9),
                        ("MB/s", 1e6), ("kB/s", 1e3)):
        if v >= div:
            return "{0:.2f} {1}".format(v / div, suffix)
    return "{0:.0f} B/s".format(v)


def human_bits(bytes_per_sec):
    try:
        v = float(bytes_per_sec) * 8.0
    except (TypeError, ValueError):
        return "-"
    for suffix, div in (("Tb/s", 1e12), ("Gb/s", 1e9),
                        ("Mb/s", 1e6), ("kb/s", 1e3)):
        if v >= div:
            return "{0:.2f} {1}".format(v / div, suffix)
    return "{0:.0f} b/s".format(v)


def human_ns(ns):
    """Nanoseconds -> compact human duration."""
    try:
        ns = int(ns)
    except (TypeError, ValueError):
        return "-"
    if ns <= 0:
        return "0s"
    if ns < 1000:
        return "{0}ns".format(ns)
    if ns < 1000000:
        return "{0:.3g}us".format(ns / 1000.0)
    if ns < NSEC_PER_SEC:
        return "{0:.3g}ms".format(ns / 1000000.0)
    secs = ns // NSEC_PER_SEC
    if secs < 60:
        return "{0}s".format(secs)
    parts = []
    days, secs = divmod(secs, 86400)
    hours, secs = divmod(secs, 3600)
    mins, secs = divmod(secs, 60)
    if days:
        parts.append("{0}d".format(days))
    if hours:
        parts.append("{0}h".format(hours))
    if mins and len(parts) < 2:
        parts.append("{0}m".format(mins))
    if secs and len(parts) < 2:
        parts.append("{0}s".format(secs))
    return "".join(parts) if parts else "0s"


def monotonic_ns():
    """Same clock as bpf_ktime_get_ns(): CLOCK_MONOTONIC, nanoseconds."""
    if hasattr(time, "clock_gettime_ns"):
        try:
            return time.clock_gettime_ns(time.CLOCK_MONOTONIC)
        except Exception:
            pass
    return int(time.monotonic() * 1e9)


def wallclock_from_monotonic(mono_ns, now_mono=None, now_wall=None):
    """Map a monotonic kernel timestamp onto local wall-clock seconds."""
    if now_mono is None:
        now_mono = monotonic_ns()
    if now_wall is None:
        now_wall = time.time()
    return now_wall - (now_mono - int(mono_ns)) / 1e9


def fmt_time(mono_ns, now_mono=None, now_wall=None, with_date=False):
    try:
        secs = wallclock_from_monotonic(mono_ns, now_mono, now_wall)
    except Exception:
        return "-"
    if secs <= 0:
        return "-"
    fmt = "%Y-%m-%d %H:%M:%S" if with_date else "%H:%M:%S"
    try:
        return time.strftime(fmt, time.localtime(secs))
    except Exception:
        return "-"


def decode_flags(value, table):
    try:
        value = int(value)
    except (TypeError, ValueError):
        return []
    out = []
    for bit, name in table:
        if value & (1 << bit):
            out.append(name)
    return out


def flags_str(value, table, empty="-"):
    names = decode_flags(value, table)
    return ",".join(names) if names else empty


def truncate(text, width):
    text = str(text)
    if width <= 0:
        return ""
    if len(text) <= width:
        return text
    if width <= 1:
        return text[:width]
    return text[:width - 1] + "…" if unicode_ok() else text[:width - 1] + "~"


# ---------------------------------------------------------------------------
# Value parsers - the exact syntax documented in calyanti.conf
# ---------------------------------------------------------------------------

_DUR_UNITS = [("ns", 1), ("us", 1000), ("ms", 1000000),
              ("s", NSEC_PER_SEC), ("m", 60 * NSEC_PER_SEC),
              ("h", 3600 * NSEC_PER_SEC), ("d", 86400 * NSEC_PER_SEC)]


def parse_duration(text):
    """'10m' -> ns. A bare integer means SECONDS, as in calyanti.conf."""
    if text is None:
        raise CalyError("empty duration")
    s = str(text).strip().lower().replace(" ", "")
    if not s:
        raise CalyError("empty duration")
    if s in ("0", "never", "permanent", "perm", "forever"):
        return 0
    m = re.match(r"^(\d+(?:\.\d+)?)([a-z]*)$", s)
    if not m:
        raise CalyError("bad duration {0!r} (try 30s, 10m, 4h, 2d)".format(text))
    value, unit = float(m.group(1)), m.group(2)
    if unit == "":
        return int(round(value * NSEC_PER_SEC))
    for name, mult in _DUR_UNITS:
        if unit == name:
            return int(round(value * mult))
    raise CalyError("unknown duration unit {0!r} in {1!r} "
                    "(ns us ms s m h d)".format(unit, text))


def parse_scaled(text, what="value", binary_ok=True):
    """'2k' -> 2000, '64ki' -> 65536. Rates use k/m/g = 1e3/1e6/1e9."""
    if text is None:
        raise CalyError("empty {0}".format(what))
    s = str(text).strip().lower().replace(" ", "").replace("_", "")
    if not s:
        raise CalyError("empty {0}".format(what))
    m = re.match(r"^(\d+(?:\.\d+)?)([kmgt]i?)?$", s)
    if not m:
        raise CalyError("bad {0} {1!r} (try 1000, 20k, 1.5m)".format(what, text))
    value = float(m.group(1))
    unit = m.group(2) or ""
    if unit.endswith("i"):
        if not binary_ok:
            raise CalyError("binary suffix not valid for {0}".format(what))
        mult = {"ki": 1 << 10, "mi": 1 << 20,
                "gi": 1 << 30, "ti": 1 << 40}[unit]
    elif unit:
        mult = {"k": 1e3, "m": 1e6, "g": 1e9, "t": 1e12}[unit]
    else:
        mult = 1
    return int(round(value * mult))


def parse_cidr(text):
    """Return an ipaddress network. Bare addresses become /32 or /128."""
    if ipaddress is None:
        raise CalyError("the python3 ipaddress module is missing")
    if text is None:
        raise CalyError("empty address")
    s = str(text).strip()
    if not s:
        raise CalyError("empty address")
    if "%" in s:                                  # strip a scope id
        s = s.split("%", 1)[0]
    try:
        return ipaddress.ip_network(s, strict=False)
    except ValueError as exc:
        raise CalyError("bad address/CIDR {0!r}: {1}".format(text, exc))


def parse_addr(text):
    if ipaddress is None:
        raise CalyError("the python3 ipaddress module is missing")
    s = str(text).strip()
    if "%" in s:
        s = s.split("%", 1)[0]
    try:
        return ipaddress.ip_address(s)
    except ValueError as exc:
        raise CalyError("bad address {0!r}: {1}".format(text, exc))


def parse_portspec(text):
    """'tcp/443', 'udp/53', 'tcp/8000-8100' -> (proto, first, last)."""
    if text is None:
        raise CalyError("empty port specification")
    s = str(text).strip().lower()
    if "/" in s:
        proto_s, port_s = s.split("/", 1)
    elif ":" in s:
        proto_s, port_s = s.split(":", 1)
    else:
        raise CalyError("port must be <proto>/<port>, e.g. tcp/443")
    proto_s = proto_s.strip()
    if proto_s not in ("tcp", "udp"):
        raise CalyError("port policy applies to tcp or udp only, "
                        "got {0!r}".format(proto_s))
    port_s = port_s.strip()
    if "-" in port_s:
        lo_s, hi_s = port_s.split("-", 1)
    else:
        lo_s = hi_s = port_s
    try:
        lo, hi = int(lo_s, 10), int(hi_s, 10)
    except ValueError:
        raise CalyError("bad port number in {0!r}".format(text))
    if not (0 <= lo <= 65535 and 0 <= hi <= 65535):
        raise CalyError("port out of range 0-65535 in {0!r}".format(text))
    if lo > hi:
        lo, hi = hi, lo
    return proto_s, lo, hi


def parse_mode(text):
    s = str(text).strip().lower().replace(" ", "-")
    if s in MODE_ALIASES:
        return MODE_ALIASES[s]
    try:
        v = int(s, 10)
        if v in MODE_NAMES:
            return v
    except ValueError:
        pass
    raise CalyError("unknown mode {0!r} (normal, elevated, under-attack, "
                    "lockdown, monitor)".format(text))


# ---------------------------------------------------------------------------
# Binary decoders. Every one accepts either raw bytes (bpftool without BTF) or
# a pre-formatted dict (bpftool with BTF), because which one you get depends
# on the kernel and the bpftool build, not on anything we control.
# ---------------------------------------------------------------------------

def _dget(d, name, default=0):
    v = d.get(name, default)
    if isinstance(v, str):
        try:
            return int(v, 0)
        except ValueError:
            return default
    if isinstance(v, bool):
        return int(v)
    if isinstance(v, (int, float)):
        return int(v)
    return default


def _dbytes(d, name, size):
    """Pull an address-like member out of a formatted dict as raw bytes."""
    v = d.get(name)
    if isinstance(v, list):
        out = bytearray()
        for elem in v:
            iv = elem
            if isinstance(iv, str):
                try:
                    iv = int(iv, 0)
                except ValueError:
                    return None
            if not isinstance(iv, int):
                return None
            if len(v) == size:
                out.append(iv & 0xFF)
            else:
                # array of __u32 words in native order
                out.extend(int(iv & 0xFFFFFFFF).to_bytes(4, sys.byteorder))
        return bytes(out[:size]).ljust(size, b"\0")
    if isinstance(v, str):
        try:
            return ip_to_bytes(parse_addr(v))
        except CalyError:
            return None
    return None


def ip_to_bytes(addr):
    return addr.packed


def bytes_to_ip(raw, family):
    try:
        if family == CALY_AF_INET or len(raw) == 4:
            return socket.inet_ntop(socket.AF_INET, bytes(raw[:4]))
        return socket.inet_ntop(socket.AF_INET6, bytes(raw[:16]))
    except (OSError, ValueError, socket.error):
        return "?"


def decode_fw_config(raw):
    """720 raw bytes -> dict keyed by the C field names."""
    if raw is None or len(raw) < SZ_FW_CONFIG:
        raise CalyError("short fw_config: {0} bytes, expected {1}".format(
            0 if raw is None else len(raw), SZ_FW_CONFIG))
    cfg = {}
    u64 = struct.unpack_from(FMT_FW_CONFIG_U64, raw, 0)
    for name, value in zip(FW_CONFIG_U64_FIELDS, u64):
        cfg[name] = value
    u32 = struct.unpack_from(FMT_FW_CONFIG_U32, raw, OFF_FW_CONFIG_U32)
    for name, value in zip(FW_CONFIG_U32_FIELDS, u32):
        cfg[name] = value
    ports = struct.unpack_from(FMT_FW_CONFIG_MGMT, raw, OFF_FW_CONFIG_MGMT)
    tcp_n = min(cfg.get("mgmt_tcp_count", 0), CALY_MGMT_PORTS_MAX)
    udp_n = min(cfg.get("mgmt_udp_count", 0), CALY_MGMT_PORTS_MAX)
    cfg["mgmt_tcp_ports"] = list(ports[0:tcp_n])
    cfg["mgmt_udp_ports"] = list(ports[16:16 + udp_n])
    cfg["mgmt_tcp_ports_all"] = list(ports[0:16])
    cfg["mgmt_udp_ports_all"] = list(ports[16:32])
    cfg["reserved"] = list(struct.unpack_from(FMT_FW_CONFIG_RSVD, raw,
                                              OFF_FW_CONFIG_RSVD))
    # Present the token buckets the way the rest of the CLI wants them.
    cfg["tb_rate"] = [cfg["tb_rate_" + n] for n in TB_NAMES]
    cfg["tb_burst"] = [cfg["tb_burst_" + n] for n in TB_NAMES]
    return cfg


def normalise_config(obj):
    """Accept a config from the daemon (dict) or the map (bytes)."""
    if isinstance(obj, (bytes, bytearray)):
        return decode_fw_config(obj)
    if not isinstance(obj, dict):
        raise CalyError("unusable config payload")
    cfg = dict(obj)
    for i, name in enumerate(TB_NAMES):
        if "tb_rate" in cfg and isinstance(cfg["tb_rate"], list):
            break
    if "tb_rate" not in cfg or not isinstance(cfg.get("tb_rate"), list):
        cfg["tb_rate"] = [_dget(cfg, "tb_rate_" + n) for n in TB_NAMES]
    if "tb_burst" not in cfg or not isinstance(cfg.get("tb_burst"), list):
        cfg["tb_burst"] = [_dget(cfg, "tb_burst_" + n) for n in TB_NAMES]
    if not isinstance(cfg.get("mgmt_tcp_ports"), list):
        cfg["mgmt_tcp_ports"] = []
    if not isinstance(cfg.get("mgmt_udp_ports"), list):
        cfg["mgmt_udp_ports"] = []
    return cfg


def encode_fw_config(cfg, raw):
    """Write the mutable scalar fields of `cfg` back into the 720-byte blob."""
    buf = bytearray(raw)
    values = [int(cfg.get(name, 0)) & 0xFFFFFFFFFFFFFFFF
              for name in FW_CONFIG_U64_FIELDS]
    struct.pack_into(FMT_FW_CONFIG_U64, buf, 0, *values)
    values = [int(cfg.get(name, 0)) & 0xFFFFFFFF
              for name in FW_CONFIG_U32_FIELDS]
    struct.pack_into(FMT_FW_CONFIG_U32, buf, OFF_FW_CONFIG_U32, *values)
    return bytes(buf)


def decode_ban_entry(value):
    if isinstance(value, dict):
        return {
            "expiry_ns": _dget(value, "expiry_ns"),
            "first_seen_ns": _dget(value, "first_seen_ns"),
            "last_hit_ns": _dget(value, "last_hit_ns"),
            "cur_ttl_ns": _dget(value, "cur_ttl_ns"),
            "hit_pkts": _dget(value, "hit_pkts"),
            "hit_bytes": _dget(value, "hit_bytes"),
            "reason": _dget(value, "reason"),
            "strikes": _dget(value, "strikes"),
            "offences": _dget(value, "offences"),
            "flags": _dget(value, "flags"),
        }
    f = struct.unpack(FMT_BAN_ENTRY, bytes(value[:64]))
    return {"expiry_ns": f[0], "first_seen_ns": f[1], "last_hit_ns": f[2],
            "cur_ttl_ns": f[3], "hit_pkts": f[4], "hit_bytes": f[5],
            "reason": f[6], "strikes": f[7], "offences": f[8], "flags": f[9]}


def encode_ban_entry(entry):
    return struct.pack(FMT_BAN_ENTRY,
                       entry.get("expiry_ns", 0) & 0xFFFFFFFFFFFFFFFF,
                       entry.get("first_seen_ns", 0),
                       entry.get("last_hit_ns", 0),
                       entry.get("cur_ttl_ns", 0),
                       entry.get("hit_pkts", 0),
                       entry.get("hit_bytes", 0),
                       entry.get("reason", 0) & 0xFFFFFFFF,
                       entry.get("strikes", 0) & 0xFFFFFFFF,
                       entry.get("offences", 0) & 0xFFFFFFFF,
                       entry.get("flags", 0) & 0xFFFFFFFF)


def decode_rule_meta(value):
    if isinstance(value, dict):
        return {"added_ns": _dget(value, "added_ns"),
                "hits": _dget(value, "hits"),
                "flags": _dget(value, "flags"),
                "tag": _dget(value, "tag")}
    f = struct.unpack(FMT_RULE_META, bytes(value[:24]))
    return {"added_ns": f[0], "hits": f[1], "flags": f[2], "tag": f[3]}


def encode_rule_meta(meta):
    return struct.pack(FMT_RULE_META,
                       meta.get("added_ns", 0) & 0xFFFFFFFFFFFFFFFF,
                       meta.get("hits", 0) & 0xFFFFFFFFFFFFFFFF,
                       meta.get("flags", 0) & 0xFFFFFFFF,
                       meta.get("tag", 0) & 0xFFFFFFFF)


def decode_port_rule(value):
    if isinstance(value, dict):
        return {"rate": _dget(value, "rate"), "burst": _dget(value, "burst"),
                "mode": _dget(value, "mode"), "flags": _dget(value, "flags")}
    f = struct.unpack(FMT_PORT_RULE, bytes(value[:24]))
    return {"rate": f[0], "burst": f[1], "mode": f[2], "flags": f[3]}


def encode_port_rule(rule):
    return struct.pack(FMT_PORT_RULE,
                       rule.get("rate", 0) & 0xFFFFFFFFFFFFFFFF,
                       rule.get("burst", 0) & 0xFFFFFFFFFFFFFFFF,
                       rule.get("mode", 0) & 0xFFFFFFFF,
                       rule.get("flags", 0) & 0xFFFFFFFF)


def decode_src_stats(value):
    if isinstance(value, dict):
        return {"packets": _dget(value, "packets"),
                "bytes": _dget(value, "bytes"),
                "drops": _dget(value, "drops"),
                "drop_bytes": _dget(value, "drop_bytes"),
                "first_seen_ns": _dget(value, "first_seen_ns"),
                "last_seen_ns": _dget(value, "last_seen_ns"),
                "last_reason": _dget(value, "last_reason"),
                "flags": _dget(value, "flags")}
    f = struct.unpack(FMT_SRC_STATS, bytes(value[:56]))
    return {"packets": f[0], "bytes": f[1], "drops": f[2], "drop_bytes": f[3],
            "first_seen_ns": f[4], "last_seen_ns": f[5],
            "last_reason": f[6], "flags": f[7]}


def decode_conn_state(value):
    if isinstance(value, dict):
        return {"created_ns": _dget(value, "created_ns"),
                "last_seen_ns": _dget(value, "last_seen_ns"),
                "pkts_in": _dget(value, "pkts_in"),
                "bytes_in": _dget(value, "bytes_in"),
                "pkts_out": _dget(value, "pkts_out"),
                "bytes_out": _dget(value, "bytes_out"),
                "state": _dget(value, "state"),
                "flags": _dget(value, "flags"),
                "ifindex": _dget(value, "ifindex"),
                "mark": _dget(value, "mark")}
    f = struct.unpack(FMT_CONN_STATE, bytes(value[:64]))
    return {"created_ns": f[0], "last_seen_ns": f[1], "pkts_in": f[2],
            "bytes_in": f[3], "pkts_out": f[4], "bytes_out": f[5],
            "state": f[6], "flags": f[7], "ifindex": f[8], "mark": f[9]}


def coerce_addr_key(key, family):
    """Key of caly_ban4/rate4/scan4/top4 (bare __u32, network order) or
    caly_ban6/... (struct in6_key). Handle every shape bpftool can emit:
    a raw hex byte list, a bare integer, or a BTF-formatted struct.

    A BTF-rendered in6_key is {"a":[w0,w1,w2,w3]} where each word is the
    host-interpreted value of four network-order bytes; writing each word
    back in native byte order reconstructs the original address bytes.
    """
    size = 4 if family == CALY_AF_INET else 16
    if isinstance(key, dict):
        arr = None
        for name in ("a", "in6_u", "addr", "u6_addr32", "__in6_u"):
            candidate = key.get(name)
            if isinstance(candidate, dict):
                for inner in ("u6_addr32", "u6_addr8", "__u6_addr32",
                              "__u6_addr8"):
                    if isinstance(candidate.get(inner), list):
                        candidate = candidate[inner]
                        break
            if isinstance(candidate, list):
                arr = candidate
                break
        if arr is None:
            return None
        if len(arr) == size:                       # byte array
            return bt_bytes(arr, size)
        out = bytearray()                          # word array
        for word in arr:
            if isinstance(word, str):
                try:
                    word = int(word, 0)
                except ValueError:
                    return None
            out += int(word & 0xFFFFFFFF).to_bytes(4, sys.byteorder)
        return bytes(out[:size]).ljust(size, b"\0")
    return bt_bytes(key, size)


def coerce_lpm_key(key, version):
    """Return the full prefixlen(host)+addr(network) byte image of an LPM key,
    whether bpftool gave us raw hex or a BTF-formatted {prefixlen, addr}."""
    width = 4 if version == 4 else 16
    if isinstance(key, dict):
        prefixlen = _dget(key, "prefixlen")
        data = None
        for name in ("addr", "data", "u"):
            if key.get(name) is not None:
                data = key[name]
                break
        raw = bt_bytes(data, width) if data is not None else None
        if raw is None:
            return None
        return struct.pack("=I", prefixlen) + bytes(raw[:width]).ljust(width,
                                                                      b"\0")
    return bt_bytes(key, 4 + width)


def decode_conn_key(key):
    """conn_key is ingress-oriented: saddr/sport is the REMOTE peer."""
    if isinstance(key, dict):
        saddr = _dbytes(key, "saddr", 16) or b"\0" * 16
        daddr = _dbytes(key, "daddr", 16) or b"\0" * 16
        sport = _dget(key, "sport")
        dport = _dget(key, "dport")
        proto = _dget(key, "proto")
        family = _dget(key, "family")
        # ports in the map are network order; a formatted dict already
        # byte-swapped nothing, so treat the raw 16 bits as network order.
        sport = socket.ntohs(sport & 0xFFFF)
        dport = socket.ntohs(dport & 0xFFFF)
    else:
        raw = bytes(key[:SZ_CONN_KEY])
        saddr = raw[0:16]
        daddr = raw[16:32]
        sport, dport = struct.unpack_from("!2H", raw, 32)
        proto = raw[36]
        family = raw[37]
    return {"saddr": saddr, "daddr": daddr, "sport": sport, "dport": dport,
            "proto": proto, "family": family}


def decode_event(raw):
    """88 raw bytes from the perf ring / ringbuf -> dict."""
    if len(raw) < SZ_EVENT:
        raise CalyError("short event record ({0} bytes)".format(len(raw)))
    ts_ns, ban_ttl_ns, value = struct.unpack_from(FMT_EVENT_HEAD, raw, 0)
    saddr = raw[24:40]
    daddr = raw[40:56]
    (ifindex, reason, verdict, proto, pkt_len, family,
     sport, dport, tcp_flags, mode, version) = \
        struct.unpack_from(FMT_EVENT_TAIL, raw, 56)
    return {
        "ts_ns": ts_ns, "ban_ttl_ns": ban_ttl_ns, "value": value,
        "saddr": bytes_to_ip(saddr, family), "daddr": bytes_to_ip(daddr, family),
        "ifindex": ifindex, "reason": reason, "verdict": verdict,
        "proto": proto, "pkt_len": pkt_len, "family": family,
        "sport": socket.ntohs(sport), "dport": socket.ntohs(dport),
        "tcp_flags": tcp_flags, "mode": mode, "version": version,
    }


def normalise_event(obj):
    """Accept an event from the daemon (JSON) or from decode_event()."""
    ev = dict(obj)
    ev.setdefault("ts_ns", 0)
    ev.setdefault("reason", 0)
    ev.setdefault("verdict", 0)
    for key in ("saddr", "daddr"):
        val = ev.get(key)
        if isinstance(val, (bytes, bytearray)):
            ev[key] = bytes_to_ip(val, ev.get("family", CALY_AF_INET))
        elif not isinstance(val, str):
            ev[key] = "-"
    if isinstance(ev.get("reason"), str):
        ev["reason"] = STAT_INDEX.get(ev["reason"], 0)
    if isinstance(ev.get("verdict"), str):
        rev = dict((v, k) for k, v in VERDICT_NAMES.items())
        ev["verdict"] = rev.get(ev["verdict"], 0)
    return ev


def reason_name(idx):
    try:
        idx = int(idx)
    except (TypeError, ValueError):
        return "unknown"
    if 0 <= idx < STAT_MAX:
        return STAT_NAMES[idx]
    return "unknown"


def proto_name(num):
    try:
        num = int(num)
    except (TypeError, ValueError):
        return "?"
    return PROTO_NAMES.get(num, str(num))


def tcp_flags_str(flags):
    try:
        flags = int(flags)
    except (TypeError, ValueError):
        return ""
    names = (("F", 0x01), ("S", 0x02), ("R", 0x04), ("P", 0x08),
             ("A", 0x10), ("U", 0x20), ("E", 0x40), ("C", 0x80))
    return "".join(ch for ch, bit in names if flags & bit) or "-"


def fmt_endpoint(addr, port, family=None):
    if port:
        if family == CALY_AF_INET6 or (isinstance(addr, str) and ":" in addr):
            return "[{0}]:{1}".format(addr, port)
        return "{0}:{1}".format(addr, port)
    return str(addr)


# ---------------------------------------------------------------------------
# Subprocess helper
# ---------------------------------------------------------------------------

def run_cmd(argv, timeout=20, stdin_data=None):
    """Run a command. Returns (rc, stdout_text, stderr_text).

    rc is 127 when the binary is missing, so callers never need to catch
    OSError themselves.
    """
    try:
        proc = subprocess.Popen(
            argv, stdout=subprocess.PIPE, stderr=subprocess.PIPE,
            stdin=subprocess.PIPE if stdin_data is not None else None,
            close_fds=True)
    except OSError as exc:
        if exc.errno in (errno.ENOENT, errno.EACCES, errno.EPERM):
            return 127, "", str(exc)
        return 126, "", str(exc)
    try:
        out, err = proc.communicate(
            input=stdin_data.encode("utf-8") if stdin_data else None,
            timeout=timeout)
    except subprocess.TimeoutExpired:
        try:
            proc.kill()
            proc.communicate()
        except Exception:
            pass
        return 124, "", "timed out after {0}s".format(timeout)
    return (proc.returncode,
            out.decode("utf-8", "replace") if out else "",
            err.decode("utf-8", "replace") if err else "")


def which(name):
    path_env = os.environ.get("PATH", "")
    dirs = path_env.split(os.pathsep) if path_env else []
    # sbin is routinely missing from a non-root PATH, and every tool we shell
    # out to lives there.
    dirs += ["/usr/local/sbin", "/usr/local/bin", "/usr/sbin", "/usr/bin",
             "/sbin", "/bin"]
    seen = set()
    for directory in dirs:
        if not directory or directory in seen:
            continue
        seen.add(directory)
        candidate = os.path.join(directory, name)
        if os.path.isfile(candidate) and os.access(candidate, os.X_OK):
            return candidate
    return None


def is_root():
    """True when running with effective uid 0. geteuid() is POSIX-only; on a
    platform without it we are certainly not a Linux root, so return False."""
    getuid = getattr(os, "geteuid", None)
    if getuid is None:
        return False
    try:
        return getuid() == 0
    except OSError:
        return False


def read_file(path, limit=65536):
    try:
        with open(path, "r") as handle:
            return handle.read(limit)
    except (IOError, OSError):
        return None


def read_int_file(path, default=None):
    text = read_file(path, 64)
    if text is None:
        return default
    try:
        return int(text.strip(), 10)
    except ValueError:
        return default


# ---------------------------------------------------------------------------
# bpftool JSON coercion
#
# bpftool renders map contents either as raw hex byte arrays (no BTF for the
# map, or an older build) or as pre-formatted structures (BTF available). We
# must handle both, because which one you get depends on the kernel and the
# bpftool package, not on anything we control.
# ---------------------------------------------------------------------------

def bt_bytes(value, size=None):
    """Coerce a bpftool JSON key/value into raw bytes, or None."""
    if value is None:
        return None
    if isinstance(value, (bytes, bytearray)):
        return bytes(value)
    if isinstance(value, list):
        out = bytearray()
        for elem in value:
            if isinstance(elem, bool):
                return None
            if isinstance(elem, str):
                try:
                    num = int(elem, 0)
                except ValueError:
                    return None
            elif isinstance(elem, int):
                num = elem
            else:
                return None
            if num < 0 or num > 255:
                return None
            out.append(num)
        if size is not None and len(out) < size:
            return None
        return bytes(out)
    if isinstance(value, bool):
        value = int(value)
    if isinstance(value, str):
        try:
            value = int(value, 0)
        except ValueError:
            return None
    if isinstance(value, int) and size:
        mask = (1 << (size * 8)) - 1
        return (value & mask).to_bytes(size, sys.byteorder)
    return None


def bt_uint(value, size):
    """Coerce a bpftool scalar (int, hex string, or byte list) to an int."""
    if isinstance(value, bool):
        return int(value)
    if isinstance(value, int):
        return value
    if isinstance(value, str):
        try:
            return int(value, 0)
        except ValueError:
            return 0
    raw = bt_bytes(value, size)
    if raw is None:
        return 0
    fmt = {1: "=B", 2: "=H", 4: "=I", 8: "=Q"}.get(size)
    if fmt is None:
        return 0
    return struct.unpack_from(fmt, raw, 0)[0]


def bt_u32(value):
    return bt_uint(value, 4)


def bt_u64(value):
    return bt_uint(value, 8)


def bt_percpu_sum(entry, size=8):
    """Sum a PERCPU map entry across all CPUs."""
    if "values" in entry and isinstance(entry["values"], list):
        total = 0
        for slot in entry["values"]:
            if isinstance(slot, dict):
                total += bt_uint(slot.get("value", 0), size)
            else:
                total += bt_uint(slot, size)
        return total
    if "value" in entry:
        return bt_uint(entry["value"], size)
    return 0


def hexs(raw):
    """bytes -> the 'hex aa bb cc' argument form bpftool expects."""
    return " ".join("{0:02x}".format(b) for b in bytearray(raw))


class Bpftool(object):
    """Thin, defensive wrapper around bpftool for the --direct backend."""

    def __init__(self, pin_dir=CALY_PIN_DIR, path=None, verbose=False):
        self.pin_dir = pin_dir
        self.verbose = verbose
        self.path = path or self._locate()
        self._version = None

    @staticmethod
    def _locate():
        env = os.environ.get("CALYCTL_BPFTOOL")
        if env:
            return env
        found = which("bpftool")
        if found:
            return found
        for pattern in ("/usr/lib/linux-tools/*/bpftool",
                        "/usr/lib/linux-tools-*/bpftool",
                        "/usr/libexec/bpftool"):
            matches = sorted(glob.glob(pattern))
            if matches:
                return matches[-1]
        return None

    def available(self):
        return self.path is not None

    def require(self):
        if not self.path:
            raise BackendUnavailable(
                "bpftool not found. Install it (dnf install bpftool / "
                "apt install linux-tools-common linux-tools-$(uname -r) / "
                "apk add bpftool) or point CALYCTL_BPFTOOL at it.")
        return self.path

    def version(self):
        if self._version is None:
            rc, out, err = run_cmd([self.require(), "version"])
            self._version = (out or err or "").strip().splitlines()[0] \
                if (out or err) else "unknown"
        return self._version

    def map_path(self, name):
        return os.path.join(self.pin_dir, name)

    def has_map(self, name):
        return os.path.exists(self.map_path(name))

    def require_map(self, name):
        path = self.map_path(name)
        if not os.path.exists(path):
            raise BackendUnavailable(
                "pinned map {0} is missing. Is the dataplane loaded? "
                "(looked in {1})".format(name, self.pin_dir))
        return path

    def _run_json(self, args, what):
        argv = [self.require(), "-j"] + args
        if self.verbose:
            sys.stderr.write("+ {0}\n".format(" ".join(argv)))
        rc, out, err = run_cmd(argv)
        if rc == 127:
            raise BackendUnavailable("cannot execute bpftool: {0}".format(err))
        if rc != 0:
            msg = (err or out or "").strip()
            if "Operation not permitted" in msg or "Permission denied" in msg \
                    or not is_root():
                msg += " (direct map access needs root)"
            raise CalyError("bpftool {0} failed: {1}".format(what, msg))
        text = out.strip()
        if not text:
            return []
        try:
            return json.loads(text)
        except ValueError as exc:
            raise CalyError("bpftool {0} produced unparsable JSON: "
                            "{1}".format(what, exc))

    def map_dump(self, name):
        path = self.require_map(name)
        data = self._run_json(["map", "dump", "pinned", path],
                              "dump " + name)
        if isinstance(data, dict):
            # Newer bpftool wraps dumps of some map types in an object.
            for key in ("elements", "entries", "items"):
                if isinstance(data.get(key), list):
                    return data[key]
            return []
        return data if isinstance(data, list) else []

    def map_lookup(self, name, key):
        path = self.require_map(name)
        args = ["map", "lookup", "pinned", path, "key", "hex"] + \
            hexs(key).split()
        data = self._run_json(args, "lookup " + name)
        if isinstance(data, list):
            return data[0] if data else None
        return data

    def map_update(self, name, key, value, flags=None):
        path = self.require_map(name)
        argv = [self.require(), "map", "update", "pinned", path,
                "key", "hex"] + hexs(key).split() + \
               ["value", "hex"] + hexs(value).split()
        if flags:
            argv.append(flags)
        if self.verbose:
            sys.stderr.write("+ {0}\n".format(" ".join(argv)))
        rc, out, err = run_cmd(argv)
        if rc != 0:
            raise CalyError("bpftool map update {0} failed: {1}".format(
                name, (err or out).strip()))

    def map_delete(self, name, key, ignore_missing=True):
        path = self.require_map(name)
        argv = [self.require(), "map", "delete", "pinned", path,
                "key", "hex"] + hexs(key).split()
        if self.verbose:
            sys.stderr.write("+ {0}\n".format(" ".join(argv)))
        rc, out, err = run_cmd(argv)
        if rc != 0:
            msg = (err or out).strip()
            if ignore_missing and ("No such file" in msg or
                                   "ENOENT" in msg or "not found" in msg):
                return False
            raise CalyError("bpftool map delete {0} failed: {1}".format(
                name, msg))
        return True

    def batch(self, lines):
        """Run many map commands in one bpftool invocation."""
        if not lines:
            return 0
        self.require()
        handle = None
        try:
            fd, tmp = tempfile.mkstemp(prefix="calyctl-batch-", suffix=".bt")
            handle = os.fdopen(fd, "w")
            handle.write("\n".join(lines) + "\n")
            handle.close()
            handle = None
            argv = [self.path, "batch", "file", tmp]
            if self.verbose:
                sys.stderr.write("+ {0} ({1} commands)\n".format(
                    " ".join(argv), len(lines)))
            rc, out, err = run_cmd(argv, timeout=120)
            if rc != 0:
                raise CalyError("bpftool batch failed: {0}".format(
                    (err or out).strip()))
            return len(lines)
        finally:
            if handle is not None:
                try:
                    handle.close()
                except Exception:
                    pass
            try:
                os.unlink(tmp)
            except Exception:
                pass

    def batch_update(self, name, pairs):
        path = self.require_map(name)
        lines = ["map update pinned {0} key hex {1} value hex {2}".format(
            path, hexs(k), hexs(v)) for k, v in pairs]
        return self.batch(lines)

    def batch_delete(self, name, keys):
        path = self.require_map(name)
        lines = ["map delete pinned {0} key hex {1}".format(path, hexs(k))
                 for k in keys]
        return self.batch(lines)

    def prog_list(self):
        try:
            data = self._run_json(["prog", "show"], "prog show")
        except CalyError:
            return []
        return data if isinstance(data, list) else []

    def net_list(self):
        try:
            data = self._run_json(["net", "show"], "net show")
        except CalyError:
            return []
        return data if isinstance(data, list) else []


