def py_tb_consume(tb, now_ns, rate, burst, want):
    """Faithful port of caly_tb_consume() from common.h, for the self-test."""
    CALY_TB_RATE_MAX = 4000000000
    CALY_TB_MAX_ELAPSED_NS = NSEC_PER_SEC
    if rate == 0 or burst == 0:
        return 1
    if rate > CALY_TB_RATE_MAX:
        rate = CALY_TB_RATE_MAX
    if tb["last_refill_ns"] == 0 or tb["last_refill_ns"] > now_ns:
        tb["last_refill_ns"] = now_ns
        tb["tokens"] = burst
    if now_ns - tb["last_refill_ns"] > CALY_TB_MAX_ELAPSED_NS:
        tb["last_refill_ns"] = now_ns - CALY_TB_MAX_ELAPSED_NS
    elapsed = now_ns - tb["last_refill_ns"]
    add = (elapsed * rate) // NSEC_PER_SEC
    if add > 0:
        tb["last_refill_ns"] += (add * NSEC_PER_SEC) // rate
        if tb["tokens"] + add > burst:
            tb["tokens"] = burst
        else:
            tb["tokens"] += add
    if tb["tokens"] >= want:
        tb["tokens"] -= want
        return 1
    return 0


def cmd_test(opts, session):
    results = []

    def check(name, ok, detail="", fatal=True):
        results.append({"name": name,
                        "status": "ok" if ok else ("fail" if fatal else "warn"),
                        "detail": detail})
        return ok

    check("python >= 3.6", sys.version_info >= (3, 6),
          "running {0}.{1}.{2}".format(*sys.version_info[:3]))
    check("ipaddress module", ipaddress is not None)

    # --- ABI layout, against the CALY_ASSERT numbers in common.h -----------
    sizes = [
        ("fw_config", struct.calcsize(FMT_FW_CONFIG_U64) +
         struct.calcsize(FMT_FW_CONFIG_U32) +
         struct.calcsize(FMT_FW_CONFIG_MGMT) +
         struct.calcsize(FMT_FW_CONFIG_RSVD), 720),
        ("ban_entry", struct.calcsize(FMT_BAN_ENTRY), 64),
        ("rule_meta", struct.calcsize(FMT_RULE_META), 24),
        ("port_rule", struct.calcsize(FMT_PORT_RULE), 24),
        ("token_bucket", struct.calcsize(FMT_TOKEN_BUCKET), 16),
        ("src_stats", struct.calcsize(FMT_SRC_STATS), 56),
        ("scan_state", struct.calcsize(FMT_SCAN_STATE), 96),
        ("rate_state", struct.calcsize(FMT_RATE_STATE), 128),
        ("conn_state", struct.calcsize(FMT_CONN_STATE), 64),
        ("iface_config", struct.calcsize(FMT_IFACE_CONFIG), 32),
        ("event", struct.calcsize(FMT_EVENT_HEAD) + 32 +
         struct.calcsize(FMT_EVENT_TAIL), 88),
    ]
    for name, got, want in sizes:
        check("sizeof({0}) == {1}".format(name, want), got == want,
              "computed {0}".format(got))
    offsets = [
        ("abi_version", FW_CONFIG_U64_FIELDS.index("abi_version") * 8, 0),
        ("flags", FW_CONFIG_U64_FIELDS.index("flags") * 8, 16),
        ("tb_rate", FW_CONFIG_U64_FIELDS.index("tb_rate_pps") * 8, 24),
        ("tb_burst", FW_CONFIG_U64_FIELDS.index("tb_burst_pps") * 8, 72),
        ("mode", OFF_FW_CONFIG_U32 +
         FW_CONFIG_U32_FIELDS.index("mode") * 4, 328),
        ("mgmt_tcp_ports", OFF_FW_CONFIG_MGMT, 464),
        ("mgmt_udp_ports", OFF_FW_CONFIG_MGMT_UDP, 496),
        ("reserved", OFF_FW_CONFIG_RSVD, 528),
    ]
    for name, got, want in offsets:
        check("offsetof(fw_config, {0}) == {1}".format(name, want),
              got == want, "computed {0}".format(got))
    check("fw_config u64 block is 41 fields",
          len(FW_CONFIG_U64_FIELDS) == 41,
          "have {0}".format(len(FW_CONFIG_U64_FIELDS)))
    check("fw_config u32 block is an even 34 fields",
          len(FW_CONFIG_U32_FIELDS) == 34 and
          len(FW_CONFIG_U32_FIELDS) % 2 == 0,
          "have {0}".format(len(FW_CONFIG_U32_FIELDS)))
    check("STAT_MAX == 109", STAT_MAX == 109, "have {0}".format(STAT_MAX))
    check("CALY_G_MAX == 11", GAUGE_MAX == 11, "have {0}".format(GAUGE_MAX))
    check("stat_reason names are unique",
          len(set(STAT_NAMES)) == len(STAT_NAMES))
    check("drop range 19..80 plus drop_syncookie_bad",
          STAT_NAMES[19] == "drop_eth_trunc" and
          STAT_NAMES[80] == "drop_portscan" and
          STAT_NAMES[86] == "drop_syncookie_bad")

    # --- shared arithmetic: the simulator must match the dataplane ---------
    bucket = {"tokens": 0, "last_refill_ns": 0}
    check("token bucket: rate 0 always conforms",
          py_tb_consume(bucket, 1000, 0, 100, 1) == 1)
    bucket = {"tokens": 0, "last_refill_ns": 0}
    check("token bucket: burst 0 always conforms",
          py_tb_consume(bucket, 1000, 100, 0, 1) == 1)
    bucket = {"tokens": 0, "last_refill_ns": 0}
    now = 1000000000
    first = py_tb_consume(bucket, now, 10, 10, 10)
    second = py_tb_consume(bucket, now, 10, 10, 1)
    check("token bucket: seeds full then exhausts",
          first == 1 and second == 0,
          "first={0} second={1}".format(first, second))
    bucket = {"tokens": 0, "last_refill_ns": 0}
    py_tb_consume(bucket, now, 10, 10, 10)
    refilled = py_tb_consume(bucket, now + NSEC_PER_SEC, 10, 10, 10)
    check("token bucket: refills one burst per second", refilled == 1)
    bucket = {"tokens": 0, "last_refill_ns": 0}
    py_tb_consume(bucket, now, 10, 10, 10)
    py_tb_consume(bucket, now + 100 * NSEC_PER_SEC, 10, 10, 10)
    starved = py_tb_consume(bucket, now + 100 * NSEC_PER_SEC, 10, 10, 1)
    check("token bucket: a long idle gap cannot be spent twice",
          starved == 0, "idle clamp is what stops burst amplification")

    # --- parsers ------------------------------------------------------------
    check("duration: bare integer means seconds",
          parse_duration("30") == 30 * NSEC_PER_SEC)
    check("duration: 10m", parse_duration("10m") == 600 * NSEC_PER_SEC)
    check("duration: 250ms", parse_duration("250ms") == 250000000)
    check("rate: 20k is decimal", parse_scaled("20k") == 20000)
    check("size: 64ki is binary", parse_scaled("64ki") == 65536)
    check("portspec: tcp/8000-8100",
          parse_portspec("tcp/8000-8100") == ("tcp", 8000, 8100))
    check("cidr: bare host becomes /32",
          str(parse_cidr("203.0.113.9")) == "203.0.113.9/32")
    check("cidr: v6 host becomes /128",
          str(parse_cidr("2001:db8::1")) == "2001:db8::1/128")
    check("lpm key: prefixlen first, address MSB first",
          lpm_key(parse_cidr("192.0.2.0/24")) ==
          struct.pack("=I", 24) + b"\xc0\x00\x02\x00")

    # --- live backend -------------------------------------------------------
    cfg = None
    try:
        cfg = session.config()
        check("backend reachable", True, session.describe())
    except CalyError as exc:
        check("backend reachable", False, exc.message, fatal=False)

    if cfg:
        abi = int(cfg.get("abi_version", 0))
        check("ABI major matches calyctl",
              (abi >> 16) == CALY_ABI_VERSION_MAJOR,
              "dataplane {0}.{1}, calyctl {2}.{3}".format(
                  abi >> 16, abi & 0xFFFF, CALY_ABI_VERSION_MAJOR,
                  CALY_ABI_VERSION_MINOR))
        ports = cfg.get("mgmt_tcp_ports") or []
        check("TCP/22 is in the management list", 22 in ports,
              "mgmt_tcp_ports = {0}".format(
                  ",".join(str(p) for p in ports) or "(empty)"))
        check("management list is within CALY_MGMT_PORTS_MAX",
              len(ports) <= CALY_MGMT_PORTS_MAX)
        check("master switch is on", bool(int(cfg.get("flags", 0)) & F_ENABLED),
              "CALY_F_ENABLED clear means every packet is passed",
              fatal=False)
        for name in ("vlan_max_depth", "ip6_ext_max", "tunnel_max_depth"):
            limit = {"vlan_max_depth": 2, "ip6_ext_max": 8,
                     "tunnel_max_depth": 1}[name]
            check("{0} <= compile-time bound {1}".format(name, limit),
                  int(cfg.get(name, 0)) <= limit,
                  "config says {0}".format(cfg.get(name)))

    try:
        pol4 = session.call("icmp_policy", 4)
        for icmp_type in MANDATORY_ICMP4:
            if icmp_type in pol4:
                check("icmp4 type {0} is not DROP".format(icmp_type),
                      pol4[icmp_type] != 0,
                      "type 3 code 4 is Fragmentation Needed; dropping it "
                      "black-holes PMTUD")
    except CalyError:
        pass
    try:
        pol6 = session.call("icmp_policy", 6)
        for icmp_type in MANDATORY_ICMP6:
            if icmp_type in pol6:
                check("icmp6 type {0} is not DROP".format(icmp_type),
                      pol6[icmp_type] != 0,
                      "NS/NA/RS/RA and PMTUD must never be dropped")
    except CalyError:
        pass

    try:
        allow = session.call("list_entries", "allow", limit=1)
        check("allowlist is populated", bool(allow),
              "an empty allowlist is one automation mistake away from an "
              "outage", fatal=False)
    except CalyError:
        pass

    failures = [r for r in results if r["status"] == "fail"]
    warnings = [r for r in results if r["status"] == "warn"]
    if opts.json:
        emit_json({"results": results, "failed": len(failures),
                   "warned": len(warnings), "passed":
                   len(results) - len(failures) - len(warnings)})
        return EXIT_DIAG_FAIL if failures else EXIT_OK
    pal = opts.pal
    for row in results:
        mark = {"ok": pal.paint("  ok  ", "green"),
                "warn": pal.paint(" warn ", "yellow"),
                "fail": pal.paint(" FAIL ", "bred")}[row["status"]]
        line = "[{0}] {1}".format(mark, row["name"])
        if row["detail"] and row["status"] != "ok":
            line += "\n         {0}".format(row["detail"])
        elif row["detail"] and opts.verbose:
            line += "  ({0})".format(row["detail"])
        print(line)
    print()
    print("{0} passed, {1} warned, {2} failed".format(
        len(results) - len(failures) - len(warnings),
        len(warnings), len(failures)))
    return EXIT_DIAG_FAIL if failures else EXIT_OK


# ---------------------------------------------------------------------------
# doctor - environment diagnosis
# ---------------------------------------------------------------------------

def cmd_doctor(opts, session):
    findings = []

    def add(status, name, detail=""):
        findings.append({"status": status, "name": name, "detail": detail})

    # --- privileges and interpreter ---
    if is_root():
        add("ok", "privileges", "running as root")
    else:
        add("warn", "privileges",
            "not root: direct map access and most writes will fail")

    # --- kernel ---
    release = kernel_release()
    major, minor, _patch = kernel_version_tuple()
    add("info", "kernel", release)
    if (major, minor) < (4, 18):
        add("fail", "kernel version",
            "{0} is below the supported floor of 4.18".format(release))
    else:
        add("ok", "kernel version", "{0}.{1} >= 4.18".format(major, minor))
    if (major, minor) >= (5, 15):
        add("ok", "SYN proxy helpers",
            "5.15+: bpf_tcp_raw_gen_syncookie_* available")
    else:
        add("warn", "SYN proxy helpers",
            "kernel < 5.15: the SYN proxy program is not loaded; the "
            "fallback is the per-source syn bucket + syn_fallback_pps")
    add("ok" if (major, minor) >= (5, 8) else "info", "event ringbuf",
        "5.8+: BPF_MAP_TYPE_RINGBUF" if (major, minor) >= (5, 8)
        else "kernel < 5.8: perf event array is used (always present)")

    # --- BTF ---
    if os.path.exists("/sys/kernel/btf/vmlinux"):
        try:
            size = os.path.getsize("/sys/kernel/btf/vmlinux")
        except OSError:
            size = 0
        add("ok", "kernel BTF", "/sys/kernel/btf/vmlinux ({0})".format(
            human_bytes(size)))
    else:
        add("fail", "kernel BTF",
            "/sys/kernel/btf/vmlinux is missing: CO-RE cannot work, the "
            "installer falls back to the nftables dataplane (rung 4)")

    # --- bpffs ---
    if bpffs_mounted():
        add("ok", "bpffs", "bpf filesystem mounted on " + CALY_BPFFS_ROOT)
    else:
        add("fail", "bpffs",
            "{0} is not a bpf mount. mount -t bpf bpf {0}".format(
                CALY_BPFFS_ROOT))

    pin_dir = session.pin_dir
    if os.path.isdir(pin_dir):
        try:
            present = sorted(os.listdir(pin_dir))
        except OSError as exc:
            present = []
            add("warn", "pin directory",
                "{0}: {1}".format(pin_dir, exc.strerror))
        missing = [m for m in ALL_MAP_NAMES if m not in present]
        if not present:
            add("warn", "pinned maps", "{0} is empty".format(pin_dir))
        elif missing:
            add("warn", "pinned maps",
                "{0} of {1} present; missing: {2}".format(
                    len(ALL_MAP_NAMES) - len(missing), len(ALL_MAP_NAMES),
                    ", ".join(missing[:6]) +
                    ("..." if len(missing) > 6 else "")))
        else:
            add("ok", "pinned maps",
                "all {0} maps pinned under {1}".format(
                    len(ALL_MAP_NAMES), pin_dir))
    else:
        add("warn", "pin directory",
            "{0} does not exist: the dataplane is not loaded".format(pin_dir))

    # --- tooling ---
    bt = Bpftool(pin_dir)
    if bt.available():
        add("ok", "bpftool", "{0} ({1})".format(bt.path, bt.version()))
    else:
        add("warn", "bpftool",
            "not found: --direct mode is unavailable "
            "(dnf install bpftool / apt install linux-tools-$(uname -r))")

    # --- daemon ---
    sock = session.socket_path
    if os.path.exists(sock):
        try:
            probe = DaemonBackend(sock, timeout=min(3.0, opts.timeout))
            try:
                probe.request("ping")
                add("ok", "daemon", "responding on " + sock)
            except NotSupported:
                add("ok", "daemon", "connected on {0} (no ping "
                                    "command)".format(sock))
            except CalyError as exc:
                add("warn", "daemon", "connected but unhappy: " + exc.message)
            probe.close()
        except BackendUnavailable as exc:
            add("fail", "daemon", exc.message)
    else:
        add("warn", "daemon",
            "control socket {0} is absent; is calyanti running? "
            "(systemctl status calyanti)".format(sock))

    # --- configuration sanity ---
    cfg = None
    try:
        cfg = session.config()
    except CalyError as exc:
        add("warn", "dataplane config", exc.message)
    if cfg:
        flags = int(cfg.get("flags", 0))
        abi = int(cfg.get("abi_version", 0))
        if (abi >> 16) == CALY_ABI_VERSION_MAJOR:
            add("ok", "ABI", "{0}.{1}".format(abi >> 16, abi & 0xFFFF))
        else:
            add("fail", "ABI",
                "dataplane major {0}, calyctl major {1}: refuse to trust "
                "these numbers".format(abi >> 16, CALY_ABI_VERSION_MAJOR))
        ports = cfg.get("mgmt_tcp_ports") or []
        if 22 in ports:
            add("ok", "lockout invariant",
                "TCP/22 present in mgmt_tcp_ports")
        else:
            add("fail", "lockout invariant",
                "TCP/22 is NOT in the management list; the loader is "
                "supposed to force it there")
        add("ok" if flags & F_ENABLED else "warn", "master switch",
            "enabled" if flags & F_ENABLED
            else "CALY_F_ENABLED is clear: everything is passed")
        if flags & F_MONITOR_ONLY:
            add("warn", "monitor-only",
                "the dataplane evaluates every rule and drops nothing")
        wants_synproxy = bool(flags & F_SYNPROXY)
        has_synproxy = bool(flags & F_CAP_SYNPROXY)
        if wants_synproxy and not has_synproxy:
            add("warn", "SYN proxy",
                "enabled in config but the helpers are unavailable; the "
                "per-source syn bucket is doing the work")
        elif has_synproxy:
            add("ok", "SYN proxy", "raw syncookie helpers probed and present")

    # --- sysctl drift ---
    syncookies = sysctl_get("net.ipv4.tcp_syncookies")
    want_two = bool(cfg and (int(cfg.get("flags", 0)) &
                             (F_SYNPROXY | F_CAP_SYNPROXY)) ==
                    (F_SYNPROXY | F_CAP_SYNPROXY))
    if syncookies is None:
        add("warn", "net.ipv4.tcp_syncookies", "unreadable")
    elif want_two and syncookies != "2":
        add("fail", "net.ipv4.tcp_syncookies",
            "is {0}, must be 2 when the XDP SYN proxy is active. At 1 the "
            "kernel only accepts cookies once the accept queue overflows, so "
            "cookies XDP already issued are rejected and connections die "
            "silently. Fix: {1}".format(syncookies, CALY_SYSCTL_PATH))
    elif not want_two and syncookies == "0":
        add("warn", "net.ipv4.tcp_syncookies",
            "is 0; with no XDP SYN proxy the fallback wants at least 1")
    else:
        add("ok", "net.ipv4.tcp_syncookies", syncookies)
    if os.path.exists(CALY_SYSCTL_PATH):
        add("ok", "sysctl drop-in", CALY_SYSCTL_PATH + " present")
    else:
        add("warn", "sysctl drop-in",
            "{0} is missing; sysctl settings will not survive a "
            "reboot".format(CALY_SYSCTL_PATH))
    for name, want, why in (
            ("net.core.bpf_jit_enable", ("1", "2"),
             "the JIT roughly triples XDP throughput"),
            ("kernel.unprivileged_bpf_disabled", None, None)):
        value = sysctl_get(name)
        if value is None:
            continue
        if want and value not in want:
            add("warn", name, "{0} ({1})".format(value, why))
        else:
            add("info", name, value)

    # --- virtualisation ---
    virt = detect_virt()
    if virt in ("openvz", "lxc", "lxc-libvirt"):
        add("fail", "virtualisation",
            "{0}: XDP is unavailable inside this container type; the "
            "installer must drop to the tc or nftables rung".format(virt))
    elif virt not in ("none", ""):
        add("info", "virtualisation", virt)
    else:
        add("ok", "virtualisation", "bare metal or full VM")

    # --- interfaces and attachments ---
    attachments = read_xdp_attachments()
    ours, foreign = [], []
    prog_names = {}
    if bt.available():
        for prog in bt.prog_list():
            if isinstance(prog, dict) and prog.get("id") is not None:
                prog_names[prog["id"]] = prog.get("name") or ""
    for iface in list_interfaces():
        name = iface["name"]
        att = attachments.get(name)
        if name == "lo":
            continue
        if att:
            prog_name = att.get("prog_name") or prog_names.get(
                att.get("prog_id"), "")
            if prog_name.startswith("caly"):
                ours.append("{0} ({1}, {2})".format(name, att["mode"],
                                                    prog_name))
            else:
                foreign.append("{0}: {1} id {2} in {3} mode".format(
                    name, prog_name or "unknown program",
                    att.get("prog_id"), att.get("mode")))
        add("info", "interface " + name,
            "driver {0}, {1}, mtu {2}{3}".format(
                iface["driver"], iface["operstate"], iface["mtu"],
                ", xdp " + att["mode"] if att else ""))
    if ours:
        add("ok", "xdp attachment", "; ".join(ours))
    else:
        add("warn", "xdp attachment",
            "no interface carries a caly_* XDP program")
    for entry in foreign:
        add("warn", "conflicting XDP program",
            entry + " - only one XDP program can be attached per interface")

    # --- other firewalls ---
    nft = which("nft")
    if nft:
        rc, out, _ = run_cmd([nft, "list", "ruleset"], timeout=10)
        if rc == 0 and out.strip():
            tables = len(re.findall(r"^table ", out, re.M))
            add("info", "nftables",
                "{0} table(s) loaded; harmless alongside XDP but check for "
                "duplicate policy".format(tables))
    ipt = which("iptables")
    if ipt:
        rc, out, _ = run_cmd([ipt, "-S"], timeout=10)
        if rc == 0:
            rules = [l for l in out.splitlines() if l.startswith("-A")]
            if rules:
                add("info", "iptables",
                    "{0} rule(s) in the filter table".format(len(rules)))

    # --- memlock ---
    try:
        import resource
        soft, hard = resource.getrlimit(resource.RLIMIT_MEMLOCK)
        unlimited = soft == resource.RLIM_INFINITY
        if (major, minor) >= (5, 11):
            add("ok", "RLIMIT_MEMLOCK",
                "kernel 5.11+ charges BPF memory to the memcg; the rlimit "
                "no longer matters")
        elif unlimited:
            add("ok", "RLIMIT_MEMLOCK", "unlimited")
        else:
            add("warn", "RLIMIT_MEMLOCK",
                "soft limit {0} bytes; map creation needs roughly 220 MB at "
                "shipped defaults. Set LimitMEMLOCK=infinity in the "
                "unit".format(soft))
    except Exception:
        pass

    failures = [f for f in findings if f["status"] == "fail"]
    warnings = [f for f in findings if f["status"] == "warn"]
    if opts.json:
        emit_json({"findings": findings, "failed": len(failures),
                   "warned": len(warnings)})
        return EXIT_DIAG_FAIL if failures else EXIT_OK
    pal = opts.pal
    marks = {"ok": pal.paint("  ok  ", "green"),
             "warn": pal.paint(" warn ", "yellow"),
             "fail": pal.paint(" FAIL ", "bred"),
             "info": pal.paint(" info ", "cyan")}
    for row in findings:
        if row["status"] == "info" and not opts.verbose and \
                row["name"].startswith("interface "):
            continue
        print("[{0}] {1:<26} {2}".format(marks[row["status"]], row["name"],
                                         row["detail"]))
    print()
    print("{0} ok, {1} warning(s), {2} failure(s)".format(
        len([f for f in findings if f["status"] == "ok"]),
        len(warnings), len(failures)))
    if failures:
        print(pal.paint(
            "\nAt least one hard failure. Caly Anti may not be protecting "
            "this host.", "bred"))
    return EXIT_DIAG_FAIL if failures else EXIT_OK


def cmd_version(opts, session):
    payload = {
        "calyctl": CALYCTL_VERSION,
        "abi": "{0}.{1}".format(CALY_ABI_VERSION_MAJOR,
                                CALY_ABI_VERSION_MINOR),
        "python": "{0}.{1}.{2}".format(*sys.version_info[:3]),
        "kernel": kernel_release(),
        "stat_max": STAT_MAX,
    }
    try:
        cfg = session.config()
        abi = int(cfg.get("abi_version", 0))
        payload["dataplane_abi"] = "{0}.{1}".format(abi >> 16, abi & 0xFFFF)
        payload["config_gen"] = cfg.get("config_gen", 0)
        payload["mode"] = MODE_NAMES.get(int(cfg.get("mode", 0)), "?")
    except CalyError:
        payload["dataplane_abi"] = None
    if opts.json:
        emit_json(payload)
        return EXIT_OK
    print("calyctl {0}".format(payload["calyctl"]))
    print("  ABI            {0} (compiled in)".format(payload["abi"]))
    if payload.get("dataplane_abi"):
        print("  dataplane ABI  {0}, config generation {1}, mode {2}".format(
            payload["dataplane_abi"], payload["config_gen"], payload["mode"]))
    else:
        print("  dataplane      not reachable")
    print("  python         {0}".format(payload["python"]))
    print("  kernel         {0}".format(payload["kernel"]))
    return EXIT_OK


# ---------------------------------------------------------------------------
# Live monitoring: shared sampling core for the curses TUI and the plain-text
# fallback. Nothing here touches curses, so the fallback is not a second
# implementation of the same arithmetic.
# ---------------------------------------------------------------------------

SPARK_UNICODE = " ▁▂▃▄▅▆▇█"
SPARK_ASCII = " .:-=+*#@"


def sparkline(values, width, unicode_mode=True):
    if width <= 0:
        return ""
    chars = SPARK_UNICODE if unicode_mode else SPARK_ASCII
    data = list(values)[-width:]
    if not data:
        return " " * width
    peak = max(data)
    if peak <= 0:
        return chars[0] * len(data)
    out = []
    steps = len(chars) - 1
    for value in data:
        level = int(round((float(value) / peak) * steps))
        if value > 0 and level == 0:
            level = 1
        out.append(chars[max(0, min(steps, level))])
    return "".join(out).rjust(width)


class Monitor(object):
    HISTORY = 1024

    def __init__(self, session, opts):
        self.session = session
        self.opts = opts
        self.interval = max(0.2, float(getattr(opts, "interval", 1.0) or 1.0))
        self.top_n = int(getattr(opts, "top", 8) or 8)
        self.prev = None
        self.cur = None
        self.rates = dict((n, 0.0) for n in GAUGE_NAMES)
        self.reason_rate = [0.0] * STAT_MAX
        self.pps_hist = []
        self.bps_hist = []
        self.drop_hist = []
        self.peaks = {"pps": 0.0, "bps": 0.0, "drops": 0.0}
        self.top = []
        self.status = {}
        self.config = None
        self.events = []
        self.errors = []
        self.stream = None
        self._last_top = 0.0
        self._last_status = 0.0
        self.samples = 0

    def start_stream(self):
        daemon = self.session.daemon()
        if daemon is not None:
            try:
                self.stream = daemon.event_stream()
            except Exception:
                self.stream = None
        return self.stream

    def stop(self):
        if self.stream is not None:
            self.stream.close()
            self.stream = None

    def note(self, text):
        self.errors.append((time.time(), str(text)))
        if len(self.errors) > 20:
            del self.errors[:-20]

    def sample(self):
        try:
            cur = self.session.call("stats")
        except CalyError as exc:
            self.note(exc.message)
            return False
        if self.prev is not None:
            dt = (cur["ts_ns"] - self.prev["ts_ns"]) / 1e9
            if dt > 0.01:
                for i, name in enumerate(GAUGE_NAMES):
                    self.rates[name] = rate_of(cur["gauges"][i],
                                               self.prev["gauges"][i], dt)
                self.reason_rate = [
                    rate_of(cur["packets"][i], self.prev["packets"][i], dt)
                    for i in range(STAT_MAX)]
                self.pps_hist.append(self.rates["pkts"])
                self.bps_hist.append(self.rates["bytes"])
                self.drop_hist.append(self.rates["drops"])
                for name, key in (("pkts", "pps"), ("bytes", "bps"),
                                  ("drops", "drops")):
                    if self.rates[name] > self.peaks[key]:
                        self.peaks[key] = self.rates[name]
                for hist in (self.pps_hist, self.bps_hist, self.drop_hist):
                    if len(hist) > self.HISTORY:
                        del hist[:-self.HISTORY]
        self.prev = cur
        self.cur = cur
        self.samples += 1
        return True

    def refresh_slow(self, force=False):
        now = time.time()
        if force or now - self._last_top >= max(2.0, self.interval * 3):
            self._last_top = now
            try:
                self.top = self.session.call("top", count=max(self.top_n, 10),
                                             family=None, sort="packets")
            except CalyError as exc:
                self.note(exc.message)
                self.top = []
        if force or now - self._last_status >= 10.0:
            self._last_status = now
            try:
                self.status = self.session.call("status", full=False)
                cfg = self.status.get("config")
                if isinstance(cfg, dict):
                    self.config = normalise_config(cfg)
            except CalyError as exc:
                self.note(exc.message)

    def poll_events(self):
        if self.stream is None:
            return
        for event in self.stream.poll(0.0):
            self.events.append(event)
        if len(self.events) > 500:
            del self.events[:-500]

    def reset_peaks(self):
        self.peaks = {"pps": 0.0, "bps": 0.0, "drops": 0.0}
        del self.pps_hist[:]
        del self.bps_hist[:]
        del self.drop_hist[:]

    def mode(self):
        if self.config:
            return int(self.config.get("mode", 0))
        return 0

    def ranked_drops(self, count):
        rows = [(i, self.reason_rate[i]) for i in range(STAT_MAX)
                if stat_is_drop(i) and self.reason_rate[i] > 0]
        if not rows and self.cur:
            rows = [(i, float(self.cur["packets"][i])) for i in range(STAT_MAX)
                    if stat_is_drop(i) and self.cur["packets"][i]]
            rows.sort(key=lambda r: -r[1])
            return [(i, 0.0, self.cur["packets"][i]) for i, _v in rows[:count]]
        rows.sort(key=lambda r: -r[1])
        return [(i, v, self.cur["packets"][i] if self.cur else 0)
                for i, v in rows[:count]]


def format_event_line(event, width, now_mono, now_wall):
    verdict = VERDICT_NAMES.get(int(event.get("verdict", 0)), "?")
    mark = {"pass": "P", "drop": "D", "tx": "T", "monitor": "M"}.get(
        verdict, "?")
    family = int(event.get("family", CALY_AF_INET) or CALY_AF_INET)
    src = fmt_endpoint(event.get("saddr", "?"), event.get("sport", 0), family)
    dst = ":{0}".format(event.get("dport", 0)) if event.get("dport") else ""
    text = "{0} {1} {2} -> {3}{4} {5}".format(
        fmt_time(event.get("ts_ns", 0), now_mono, now_wall),
        mark, src, dst, "", reason_name(event.get("reason", 0)))
    proto = proto_name(event.get("proto", 0))
    if proto != "?":
        text += " " + proto
    if event.get("ban_ttl_ns"):
        text += " ban " + human_ns(event["ban_ttl_ns"])
    return truncate(text, width)


# ---------------------------------------------------------------------------
# curses dashboard
# ---------------------------------------------------------------------------

class Dashboard(object):
    def __init__(self, session, opts):
        self.session = session
        self.opts = opts
        self.mon = Monitor(session, opts)
        self.paused = False
        self.show_events = True
        self.show_help = False
        self.unicode = unicode_ok() and not getattr(opts, "ascii", False)
        self.colours = {}
        self.curses = None

    # -- drawing primitives -------------------------------------------------
    def _add(self, win, y, x, text, attr=0):
        curses = self.curses
        height, width = win.getmaxyx()
        if y < 0 or y >= height or x < 0 or x >= width:
            return
        avail = width - x
        if y == height - 1:
            avail -= 1                    # never touch the very last cell
        if avail <= 0:
            return
        text = str(text)
        try:
            win.addnstr(y, x, text, avail, attr)
        except curses.error:
            pass
        except (UnicodeEncodeError, UnicodeError, ValueError):
            self.unicode = False
            try:
                win.addnstr(y, x,
                            text.encode("ascii", "replace").decode("ascii"),
                            avail, attr)
            except Exception:
                pass

    def colour(self, name, bold=False):
        attr = self.colours.get(name, 0)
        if bold and self.curses is not None:
            attr |= self.curses.A_BOLD
        return attr

    def _init_colours(self):
        curses = self.curses
        self.colours = dict((n, 0) for n in
                            ("cyan", "green", "yellow", "red", "magenta",
                             "blue", "white"))
        if not curses.has_colors():
            return
        curses.start_color()
        background = 0
        try:
            curses.use_default_colors()
            background = -1
        except curses.error:
            background = curses.COLOR_BLACK
        pairs = (("cyan", curses.COLOR_CYAN), ("green", curses.COLOR_GREEN),
                 ("yellow", curses.COLOR_YELLOW), ("red", curses.COLOR_RED),
                 ("magenta", curses.COLOR_MAGENTA),
                 ("blue", curses.COLOR_BLUE), ("white", curses.COLOR_WHITE))
        for index, (name, colour) in enumerate(pairs, start=1):
            try:
                curses.init_pair(index, colour, background)
                self.colours[name] = curses.color_pair(index)
            except curses.error:
                self.colours[name] = 0

    def mode_attr(self):
        return self.colour({0: "green", 1: "yellow", 2: "red",
                            3: "magenta", 4: "cyan"}.get(self.mon.mode(),
                                                         "white"), bold=True)

    # -- panes --------------------------------------------------------------
    def draw_header(self, win, y, width):
        curses = self.curses
        mon = self.mon
        mode_name = MODE_NAMES.get(mon.mode(), "?").upper()
        left = " Caly Anti "
        self._add(win, y, 0, " " * width, curses.A_REVERSE)
        self._add(win, y, 0, left, curses.A_REVERSE | curses.A_BOLD)
        centre = " mode: {0} ".format(mode_name)
        self._add(win, y, max(len(left) + 1, (width - len(centre)) // 2),
                  centre, curses.A_REVERSE | self.mode_attr())
        right = time.strftime("%H:%M:%S ")
        if self.paused:
            right = "PAUSED " + right
        self._add(win, y, max(0, width - len(right)), right, curses.A_REVERSE)
        y += 1

        cfg = mon.config or {}
        flags = int(cfg.get("flags", 0))
        bits = []
        if flags & F_MONITOR_ONLY:
            bits.append("MONITOR-ONLY: nothing is dropped")
        if flags and not flags & F_ENABLED:
            bits.append("DISABLED: every packet passes")
        if flags & F_CAP_SYNPROXY:
            bits.append("synproxy")
        if flags & F_CAP_RINGBUF:
            bits.append("ringbuf")
        elif flags:
            bits.append("perf-events")
        summary = "backend {0}   {1}".format(
            self.session.describe(), "  ".join(bits))
        self._add(win, y, 1, truncate(summary, width - 2),
                  self.colour("blue"))
        return y + 1

    def draw_rates(self, win, y, width, height):
        mon = self.mon
        avail = max(10, width - 34)
        headline = "pps {0:>9}  peak {1:>9}   drops/s {2:>9}  ({3:.2f}%)".format(
            human_count(mon.rates.get("pkts", 0)),
            human_count(mon.peaks["pps"]),
            human_count(mon.rates.get("drops", 0)),
            (100.0 * mon.rates.get("drops", 0) /
             mon.rates["pkts"]) if mon.rates.get("pkts") else 0.0)
        self._add(win, y, 1, headline, self.colour("cyan", bold=True))
        y += 1
        self._add(win, y, 1, sparkline(mon.pps_hist, avail, self.unicode),
                  self.colour("green"))
        y += 1
        headline = "bps {0:>11}  {1:>11}  peak {2:>11}".format(
            human_bps(mon.rates.get("bytes", 0)),
            human_bits(mon.rates.get("bytes", 0)),
            human_bps(mon.peaks["bps"]))
        self._add(win, y, 1, headline, self.colour("cyan", bold=True))
        y += 1
        self._add(win, y, 1, sparkline(mon.bps_hist, avail, self.unicode),
                  self.colour("blue"))
        y += 1
        extra = ("syn/s {0}   newconn/s {1}   udp/s {2}   icmp/s {3}   "
                 "frag/s {4}   synproxy tx/s {5}").format(
            human_count(mon.rates.get("syn", 0)),
            human_count(mon.rates.get("newconn", 0)),
            human_count(mon.rates.get("udp", 0)),
            human_count(mon.rates.get("icmp", 0)),
            human_count(mon.rates.get("frag", 0)),
            human_count(mon.rates.get("synproxy_tx", 0)))
        self._add(win, y, 1, truncate(extra, width - 2))
        return y + 1

    def draw_split(self, win, y, width, rows):
        if rows <= 1:
            return y
        left_w = max(24, int(width * 0.52))
        right_x = left_w + 2
        right_w = max(0, width - right_x - 1)
        self._add(win, y, 1, "drop reasons   (per second / total)",
                  self.colour("red", bold=True))
        if right_w > 12:
            self._add(win, y, right_x, "top talkers   (packets / drops)",
                      self.colour("yellow", bold=True))
        body = rows - 1
        drops = self.mon.ranked_drops(body)
        for i in range(body):
            line_y = y + 1 + i
            if i < len(drops):
                idx, rate, total = drops[i]
                text = "{0:<28} {1:>8} {2:>9}".format(
                    truncate(STAT_NAMES[idx], 28), human_count(rate),
                    human_count(total))
                self._add(win, line_y, 1, truncate(text, left_w))
            if right_w > 12 and i < len(self.mon.top):
                row = self.mon.top[i]
                text = "{0:<32} {1:>8} {2:>8}".format(
                    truncate(row.get("addr", "?"), 32),
                    human_count(row.get("packets", 0)),
                    human_count(row.get("drops", 0)))
                self._add(win, line_y, right_x, truncate(text, right_w))
        if not drops:
            self._add(win, y + 1, 3, "(no drops recorded)",
                      self.colour("green"))
        if right_w > 12 and not self.mon.top:
            self._add(win, y + 1, right_x + 2,
                      "(no per-source statistics)", self.colour("blue"))
        return y + rows

    def draw_events(self, win, y, width, rows):
        if rows <= 1:
            return y
        title = "recent events"
        if self.mon.stream is None:
            title += "   (no event stream: needs the daemon)"
        self._add(win, y, 1, title, self.colour("magenta", bold=True))
        now_mono, now_wall = monotonic_ns(), time.time()
        body = rows - 1
        events = self.mon.events[-body:]
        for i, event in enumerate(events):
            attr = 0
            if int(event.get("verdict", 0)) == 1:
                attr = self.colour("red")
            elif int(event.get("verdict", 0)) == 3:
                attr = self.colour("yellow")
            self._add(win, y + 1 + i, 2,
                      format_event_line(event, width - 3, now_mono, now_wall),
                      attr)
        if not events:
            note = self.mon.errors[-1][1] if self.mon.errors else \
                "(waiting for events)"
            self._add(win, y + 1, 3, truncate(note, width - 4),
                      self.colour("blue"))
        return y + rows

    def draw_footer(self, win, y, width):
        curses = self.curses
        keys = " q quit   p pause   e events   r reset peaks   +/- interval " \
               "  h help "
        self._add(win, y, 0, " " * width, curses.A_REVERSE)
        self._add(win, y, 0, truncate(keys, width - 20), curses.A_REVERSE)
        right = "{0}  {1:.1f}s ".format(self.session.describe(),
                                        self.mon.interval)
        self._add(win, y, max(0, width - len(right) - 1), right,
                  curses.A_REVERSE)

    def draw_help(self, win, height, width):
        lines = [
            "calyctl dashboard",
            "",
            "  q, Esc     quit",
            "  p          pause / resume sampling",
            "  e          show or hide the event pane",
            "  r          reset peaks and clear the sparkline history",
            "  +  -       sample faster / slower (0.2s .. 10s)",
            "  h, ?       this help",
            "",
            "  Sparklines are scaled to the peak of the visible window.",
            "  Drop reasons are per-second rates; the second column is the",
            "  lifetime total from caly_stats.",
            "",
            "  Management ports and the allowlist bypass every drop rule,",
            "  in every mode, including under-attack and lockdown.",
            "",
            "  press any key to close",
        ]
        box_h = min(height - 2, len(lines) + 2)
        box_w = min(width - 4, 68)
        top = max(0, (height - box_h) // 2)
        left = max(0, (width - box_w) // 2)
        for i in range(box_h):
            self._add(win, top + i, left, " " * box_w, self.curses.A_REVERSE)
        for i, text in enumerate(lines[:box_h - 2]):
            self._add(win, top + 1 + i, left + 2, truncate(text, box_w - 4),
                      self.curses.A_REVERSE)

    # -- main loop ----------------------------------------------------------
    def draw(self, stdscr):
        height, width = stdscr.getmaxyx()
        stdscr.erase()
        if height < 6 or width < 40:
            self._add(stdscr, 0, 0, "terminal too small")
            stdscr.noutrefresh()
            self.curses.doupdate()
            return
        y = self.draw_header(stdscr, 0, width)
        y = self.draw_rates(stdscr, y, width, height)
        self._add(stdscr, y, 0, "-" * width, self.colour("blue"))
        y += 1
        footer_y = height - 1
        remaining = footer_y - y
        events_rows = 0
        if self.show_events and remaining >= 10:
            events_rows = min(8, max(3, remaining // 3))
        split_rows = remaining - events_rows - (1 if events_rows else 0)
        y = self.draw_split(stdscr, y, width, split_rows)
        if events_rows:
            self._add(stdscr, y, 0, "-" * width, self.colour("blue"))
            y += 1
            self.draw_events(stdscr, y, width, events_rows)
        self.draw_footer(stdscr, footer_y, width)
        if self.show_help:
            self.draw_help(stdscr, height, width)
        stdscr.noutrefresh()
        self.curses.doupdate()

    def handle_key(self, key):
        curses = self.curses
        if key in (ord("q"), ord("Q"), 27):
            return False
        if self.show_help:
            self.show_help = False
            return True
        if key in (ord("p"), ord("P"), ord(" ")):
            self.paused = not self.paused
        elif key in (ord("e"), ord("E")):
            self.show_events = not self.show_events
        elif key in (ord("r"), ord("R")):
            self.mon.reset_peaks()
        elif key in (ord("h"), ord("H"), ord("?")):
            self.show_help = True
        elif key in (ord("+"), ord("=")):
            self.mon.interval = max(0.2, self.mon.interval / 2.0)
        elif key in (ord("-"), ord("_")):
            self.mon.interval = min(10.0, self.mon.interval * 2.0)
        elif key == curses.KEY_RESIZE:
            if hasattr(curses, "update_lines_cols"):
                try:
                    curses.update_lines_cols()
                except Exception:
                    pass
        return True

    def run(self):
        import curses
        self.curses = curses
        try:
            import locale
            locale.setlocale(locale.LC_ALL, "")
        except Exception:
            self.unicode = False
        stdscr = None
        try:
            stdscr = curses.initscr()
            curses.noecho()
            curses.cbreak()
            stdscr.keypad(True)
            try:
                curses.curs_set(0)
            except curses.error:
                pass
            self._init_colours()
            stdscr.timeout(100)
            self.mon.start_stream()
            self.mon.sample()
            self.mon.refresh_slow(force=True)
            next_sample = time.time() + self.mon.interval
            self.draw(stdscr)
            while True:
                try:
                    key = stdscr.getch()
                except KeyboardInterrupt:
                    break
                if key != -1:
                    if not self.handle_key(key):
                        break
                    self.draw(stdscr)
                self.mon.poll_events()
                now = time.time()
                if now >= next_sample:
                    next_sample = now + self.mon.interval
                    if not self.paused:
                        self.mon.sample()
                        self.mon.refresh_slow()
                    self.draw(stdscr)
                elif self.mon.events:
                    self.draw(stdscr)
        except KeyboardInterrupt:
            pass
        finally:
            self.mon.stop()
            if stdscr is not None:
                try:
                    stdscr.keypad(False)
                except Exception:
                    pass
            try:
                curses.nocbreak()
                curses.echo()
                curses.endwin()
            except Exception:
                pass
        return EXIT_OK


def run_plain_watch(opts, session, reason=None):
    """Text fallback: no curses, no TTY, or --plain."""
    mon = Monitor(session, opts)
    mon.start_stream()
    is_tty = False
    try:
        is_tty = sys.stdout.isatty()
    except Exception:
        pass
    if reason and is_tty:
        sys.stderr.write("calyctl: {0}; falling back to plain text\n".format(
            reason))
    pal = opts.pal
    try:
        while True:
            mon.sample()
            mon.refresh_slow()
            mon.poll_events()
            if is_tty:
                sys.stdout.write("\033[H\033[2J")
            else:
                sys.stdout.write("\n" + "-" * 72 + "\n")
            cfg = mon.config or {}
            mode = MODE_NAMES.get(int(cfg.get("mode", 0)), "?").upper()
            print("{0}  mode {1}  backend {2}  {3}".format(
                pal.paint("Caly Anti", "bcyan"),
                pal.paint(mode, mode_colour(int(cfg.get("mode", 0)))),
                session.describe(), time.strftime("%H:%M:%S")))
            print("  pps {0:>10}   bps {1:>12} ({2})   drops/s {3:>10}".format(
                human_count(mon.rates.get("pkts", 0)),
                human_bps(mon.rates.get("bytes", 0)),
                human_bits(mon.rates.get("bytes", 0)),
                human_count(mon.rates.get("drops", 0))))
            print("  syn/s {0:>8}   newconn/s {1:>8}   udp/s {2:>8}   "
                  "icmp/s {3:>8}".format(
                      human_count(mon.rates.get("syn", 0)),
                      human_count(mon.rates.get("newconn", 0)),
                      human_count(mon.rates.get("udp", 0)),
                      human_count(mon.rates.get("icmp", 0))))
            drops = mon.ranked_drops(8)
            if drops:
                print("\n  " + pal.paint("drop reasons", "bred"))
                print_table([(STAT_NAMES[i], human_count(rate),
                              human_count(total)) for i, rate, total in drops],
                            ("reason", "per second", "total"),
                            ["l", "r", "r"], pal, indent="    ")
            if mon.top:
                print("\n  " + pal.paint("top talkers", "byellow"))
                print_table([(r.get("addr", "?"), human_count(r.get("packets", 0)),
                              human_count(r.get("drops", 0)),
                              reason_name(r.get("last_reason", 0)))
                             for r in mon.top[:8]],
                            ("source", "packets", "drops", "last reason"),
                            ["l", "r", "r", "l"], pal, indent="    ")
            if mon.events:
                print("\n  " + pal.paint("recent events", "magenta"))
                now_mono, now_wall = monotonic_ns(), time.time()
                for event in mon.events[-6:]:
                    print("    " + format_event_line(event, 100, now_mono,
                                                     now_wall))
            if mon.errors and time.time() - mon.errors[-1][0] < mon.interval * 3:
                print("\n  " + pal.paint("last error: " + mon.errors[-1][1],
                                         "yellow"))
            sys.stdout.flush()
            time.sleep(mon.interval)
    except KeyboardInterrupt:
        print()
    finally:
        mon.stop()
    return EXIT_OK


def run_watch(opts, session):
    # Probe the backend once up front so a total outage exits cleanly with a
    # real error, instead of a live view that silently displays zeros forever.
    session.call("stats")
    if getattr(opts, "plain", False):
        return run_plain_watch(opts, session)
    try:
        is_tty = sys.stdout.isatty() and sys.stdin.isatty()
    except Exception:
        is_tty = False
    if not is_tty:
        return run_plain_watch(opts, session, "not a terminal")
    try:
        import curses                                   # noqa: F401
    except ImportError:
        return run_plain_watch(opts, session, "the curses module is missing")
    if os.environ.get("TERM", "") in ("", "dumb"):
        return run_plain_watch(opts, session, "TERM is unset or dumb")
    try:
        return Dashboard(session, opts).run()
    except Exception as exc:
        # A curses failure must never cost the operator their view of the box.
        return run_plain_watch(opts, session,
                               "curses failed ({0})".format(exc))


def cmd_dashboard(opts, session):
    return run_watch(opts, session)


