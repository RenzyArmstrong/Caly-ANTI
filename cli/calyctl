# Lockout protection
# ---------------------------------------------------------------------------

def split_hostport(text):
    """'1.2.3.4:22' / '[::1]:22' / '1.2.3.4%eth0:22' -> (host, port)."""
    text = str(text).strip()
    if not text:
        return None, None
    if text.startswith("["):
        end = text.find("]")
        if end < 0:
            return None, None
        host = text[1:end]
        rest = text[end + 1:]
        port = rest[1:] if rest.startswith(":") else None
    elif text.count(":") > 1:
        # Bare IPv6 with no brackets: ss prints '2001:db8::1:22'.
        idx = text.rfind(":")
        host, port = text[:idx], text[idx + 1:]
    elif ":" in text:
        host, port = text.split(":", 1)
    else:
        host, port = text, None
    if "%" in host:
        host = host.split("%", 1)[0]
    try:
        port = int(port) if port not in (None, "", "*") else None
    except ValueError:
        port = None
    return host, port


def admin_source_addresses(mgmt_ports=None):
    """Every address that could be the operator's own session.

    Sources: SSH_CLIENT / SSH_CONNECTION for this process, `who` for other
    logins, and established sockets on management ports. Best effort by
    design - a false positive costs one --force, a false negative costs a
    truck roll.
    """
    ports = set(int(p) for p in (mgmt_ports or []) if p) or set()
    ports.add(22)
    found = {}

    def record(text, why):
        if not text:
            return
        try:
            addr = parse_addr(text)
        except CalyError:
            return
        if addr.is_loopback or addr.is_unspecified:
            return
        found.setdefault(addr, why)

    for var in ("SSH_CLIENT", "SSH_CONNECTION"):
        value = os.environ.get(var)
        if value:
            record(value.split()[0], "$" + var)

    who_bin = which("who")
    if who_bin:
        rc, out, _ = run_cmd([who_bin], timeout=5)
        if rc == 0:
            for line in out.splitlines():
                match = re.search(r"\(([^)]+)\)\s*$", line)
                if match:
                    host, _port = split_hostport(match.group(1))
                    record(host, "logged-in session")

    ss_bin = which("ss")
    if ss_bin:
        rc, out, _ = run_cmd([ss_bin, "-Htn", "state", "established"],
                             timeout=5)
        if rc != 0:
            rc, out, _ = run_cmd([ss_bin, "-tn", "state", "established"],
                                 timeout=5)
        if rc == 0:
            for line in out.splitlines():
                fields = line.split()
                if len(fields) < 4:
                    continue
                if fields[0] in ("Recv-Q", "State"):
                    continue
                local, peer = fields[2], fields[3]
                _lhost, lport = split_hostport(local)
                phost, _pport = split_hostport(peer)
                if lport in ports:
                    record(phost, "connected to port {0}".format(lport))
    return found


def lockout_guard(nets, opts, action, mgmt_ports=None, pal=None):
    """Refuse to cut off the operator without --force.

    Applies to any action that could remove protection from the address the
    operator is currently using: ban, block, and removal from the allowlist.
    """
    pal = pal or Palette(False)
    nets = [n for n in nets if n is not None]
    for net in nets:
        if net.prefixlen == 0:
            raise CalyError(
                "refusing to {0} the default route {1}. That takes the "
                "machine off the network; there is no --force for it."
                .format(action, net), EXIT_REFUSED)

    admins = admin_source_addresses(mgmt_ports)
    hits = []
    for addr, why in admins.items():
        for net in nets:
            if addr.version == net.version and addr in net:
                hits.append((addr, net, why))
    if not hits:
        return
    bar = "=" * 72
    sys.stderr.write(pal.paint(bar + "\n", "bred"))
    sys.stderr.write(pal.paint(
        "  DANGER: this would {0} the address you are connected from\n".format(
            action), "bred"))
    sys.stderr.write(pal.paint(bar + "\n", "bred"))
    for addr, net, why in hits:
        sys.stderr.write("  {0:<40} matches {1}   [{2}]\n".format(
            str(addr), str(net), why))
    sys.stderr.write(
        "\n  Management ports (TCP/22 always among them) are checked before\n"
        "  every drop rule, so an SSH session on a management port survives\n"
        "  this. Anything else from that address will not.\n")
    if not getattr(opts, "force", False):
        sys.stderr.write(pal.paint(
            "\n  Refused. Re-run with --force if you really mean it.\n",
            "bred"))
        raise CalyError("aborted: {0} would cover the current admin source"
                        .format(action), EXIT_REFUSED)
    sys.stderr.write(pal.paint(
        "\n  --force given: proceeding anyway.\n\n", "byellow"))


def confirm(opts, prompt, default=False):
    """Confirm a destructive action. --yes skips; no TTY refuses."""
    if getattr(opts, "yes", False):
        return True
    if not sys.stdin.isatty():
        raise CalyError(
            "refusing to run a destructive action without a terminal; "
            "pass --yes if this is intentional", EXIT_REFUSED)
    suffix = " [y/N] " if not default else " [Y/n] "
    try:
        answer = input(prompt + suffix).strip().lower()
    except (EOFError, KeyboardInterrupt):
        sys.stderr.write("\naborted\n")
        return False
    if not answer:
        return default
    return answer in ("y", "yes")


# ---------------------------------------------------------------------------
# Session: picks a backend, and falls back cleanly when one cannot serve a
# request. The daemon is preferred; the pinned maps are the break-glass path.
# ---------------------------------------------------------------------------

def find_socket(explicit):
    if explicit:
        return explicit
    env = os.environ.get("CALYCTL_SOCKET")
    if env:
        return env
    for candidate in SOCKET_CANDIDATES:
        if os.path.exists(candidate):
            return candidate
    return SOCKET_CANDIDATES[0]


class Session(object):
    def __init__(self, opts):
        self.opts = opts
        self.socket_path = find_socket(getattr(opts, "socket", None))
        self.pin_dir = getattr(opts, "pin_dir", None) or \
            os.environ.get("CALYCTL_PIN_DIR") or CALY_PIN_DIR
        self._daemon = None
        self._direct = None
        self._daemon_failed = None
        self._direct_failed = None
        self.used = []

    # --- backend construction ---
    def daemon(self):
        if getattr(self.opts, "direct", False):
            return None
        if self._daemon is not None:
            return self._daemon
        if self._daemon_failed is not None:
            return None
        try:
            self._daemon = DaemonBackend(
                self.socket_path,
                timeout=float(getattr(self.opts, "timeout", 5.0)),
                verbose=getattr(self.opts, "verbose", 0) >= 2)
        except BackendUnavailable as exc:
            self._daemon_failed = exc.message
            return None
        return self._daemon

    def direct(self):
        if getattr(self.opts, "daemon_only", False):
            return None
        if self._direct is not None:
            return self._direct
        if self._direct_failed is not None:
            return None
        try:
            self._direct = DirectBackend(
                self.pin_dir, verbose=getattr(self.opts, "verbose", 0) >= 2)
        except BackendUnavailable as exc:
            self._direct_failed = exc.message
            return None
        return self._direct

    def backends(self):
        out = []
        daemon = self.daemon()
        if daemon is not None:
            out.append(daemon)
        direct = self.direct()
        if direct is not None:
            out.append(direct)
        return out

    def describe(self):
        if self._daemon is not None:
            return "daemon ({0})".format(self.socket_path)
        if self._direct is not None:
            return "direct ({0})".format(self.pin_dir)
        return "none"

    def warn_fallback(self):
        if self._daemon_failed and self._direct is not None and \
                not getattr(self.opts, "json", False) and \
                getattr(self.opts, "verbose", 0) >= 0:
            sys.stderr.write(
                "calyctl: daemon unreachable ({0}); reading the pinned maps "
                "directly\n".format(self._daemon_failed))

    def call(self, method, *args, **kwargs):
        backends = self.backends()
        if not backends:
            raise BackendUnavailable(
                "no backend available.\n"
                "  daemon: {0}\n"
                "  direct: {1}\n"
                "Try: calyctl doctor".format(
                    self._daemon_failed or "not tried",
                    self._direct_failed or "not tried"))
        problems = []
        first = True
        for backend in backends:
            try:
                result = getattr(backend, method)(*args, **kwargs)
                if backend is self._direct and not first:
                    self.warn_fallback()
                if backend.name not in self.used:
                    self.used.append(backend.name)
                return result
            except NotSupported as exc:
                problems.append("{0}: {1}".format(backend.name, exc.message))
            except BackendUnavailable as exc:
                problems.append("{0}: {1}".format(backend.name, exc.message))
                if backend is self._daemon:
                    self._daemon = None
                    self._daemon_failed = exc.message
                else:
                    self._direct = None
                    self._direct_failed = exc.message
            first = False
        raise CalyError("{0} failed on every backend:\n  {1}".format(
            method, "\n  ".join(problems)))

    def config(self):
        return self.call("config")

    def close(self):
        for backend in (self._daemon, self._direct):
            if backend is not None:
                backend.close()


