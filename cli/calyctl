# ---------------------------------------------------------------------------
# Daemon backend - newline-delimited JSON over the unix control socket
# ---------------------------------------------------------------------------

class EventStream(object):
    """A second control connection subscribed to the event feed."""

    def __init__(self, sock):
        self.sock = sock
        self.buf = b""
        self.closed = False

    def fileno(self):
        return self.sock.fileno()

    def poll(self, timeout=0.0):
        """Return a list of decoded events, without blocking beyond timeout."""
        out = []
        if self.closed:
            return out
        try:
            ready, _, _ = select.select([self.sock], [], [], timeout)
        except (OSError, ValueError, select.error):
            self.close()
            return out
        if not ready:
            return out
        try:
            chunk = self.sock.recv(65536)
        except (socket.timeout, BlockingIOError):
            return out
        except (OSError, socket.error):
            self.close()
            return out
        if not chunk:
            self.close()
            return out
        self.buf += chunk
        while b"\n" in self.buf:
            line, self.buf = self.buf.split(b"\n", 1)
            line = line.strip()
            if not line:
                continue
            try:
                msg = json.loads(line.decode("utf-8", "replace"))
            except ValueError:
                continue
            if isinstance(msg, dict) and isinstance(msg.get("event"), dict):
                out.append(normalise_event(msg["event"]))
        if len(self.buf) > (1 << 23):
            self.buf = b""
        return out

    def close(self):
        self.closed = True
        try:
            self.sock.close()
        except Exception:
            pass


class DaemonBackend(Backend):
    name = "daemon"
    MAX_LINE = 8 << 20

    def __init__(self, path, timeout=5.0, verbose=False):
        self.path = path
        self.timeout = timeout
        self.verbose = verbose
        self.sock = None
        self.buf = b""
        self.seq = 0
        self._connect()

    def _connect(self):
        if not hasattr(socket, "AF_UNIX"):
            raise BackendUnavailable(
                "this platform has no AF_UNIX support; the control socket is "
                "unreachable")
        try:
            sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
            sock.settimeout(self.timeout)
            sock.connect(self.path)
        except (OSError, socket.error) as exc:
            raise BackendUnavailable(
                "cannot reach the calyanti daemon on {0}: {1}".format(
                    self.path, getattr(exc, "strerror", None) or exc))
        self.sock = sock

    def close(self):
        if self.sock is not None:
            try:
                self.sock.close()
            except Exception:
                pass
            self.sock = None

    def _send(self, payload):
        data = (json.dumps(payload, separators=(",", ":")) + "\n").encode("utf-8")
        if self.verbose:
            sys.stderr.write("> {0}".format(data.decode("utf-8")))
        try:
            self.sock.sendall(data)
        except (OSError, socket.error) as exc:
            raise BackendUnavailable(
                "control socket write failed: {0}".format(exc))

    def _readline(self):
        deadline = time.time() + self.timeout
        while b"\n" not in self.buf:
            remaining = deadline - time.time()
            if remaining <= 0:
                raise CalyError("timed out waiting for the daemon "
                                "(try --timeout)")
            try:
                self.sock.settimeout(remaining)
                chunk = self.sock.recv(65536)
            except socket.timeout:
                raise CalyError("timed out waiting for the daemon "
                                "(try --timeout)")
            except (OSError, socket.error) as exc:
                raise BackendUnavailable(
                    "control socket read failed: {0}".format(exc))
            if not chunk:
                raise BackendUnavailable(
                    "the daemon closed the control connection")
            self.buf += chunk
            if len(self.buf) > self.MAX_LINE:
                raise CalyError("daemon sent an oversized response line")
        line, self.buf = self.buf.split(b"\n", 1)
        if self.verbose:
            sys.stderr.write("< {0}\n".format(line.decode("utf-8", "replace")))
        return line

    def request(self, cmd, **args):
        if self.sock is None:
            self._connect()
        self.seq += 1
        payload = {"id": self.seq, "cmd": cmd}
        clean = dict((k, v) for k, v in args.items() if v is not None)
        if clean:
            payload["args"] = clean
        self._send(payload)
        # Skip any unsolicited stream lines that arrive on this connection.
        for _ in range(64):
            line = self._readline()
            try:
                msg = json.loads(line.decode("utf-8", "replace"))
            except ValueError as exc:
                raise CalyError("daemon sent malformed JSON: {0}".format(exc))
            if not isinstance(msg, dict):
                raise CalyError("daemon sent a non-object response")
            if "stream" in msg and "ok" not in msg:
                continue
            if "id" in msg and msg["id"] != self.seq:
                continue
            if msg.get("ok"):
                data = msg.get("data")
                return data if isinstance(data, dict) else {}
            code = str(msg.get("code", ""))
            text = str(msg.get("error", "the daemon refused the request"))
            if code in ("unknown_command", "not_implemented", "unsupported"):
                raise NotSupported("daemon does not implement {0!r}: "
                                   "{1}".format(cmd, text))
            raise CalyError("daemon: {0}".format(text))
        raise CalyError("daemon never answered request {0}".format(cmd))

    # --- reads ---
    def status(self, full=False):
        data = self.request("status", full=bool(full) or None)
        data.setdefault("backend", "daemon")
        data.setdefault("socket", self.path)
        if isinstance(data.get("config"), dict):
            data["config"] = normalise_config(data["config"])
        return data

    def config(self):
        data = self.request("status")
        cfg = data.get("config")
        if not isinstance(cfg, dict):
            raise NotSupported("daemon status carried no config block")
        return normalise_config(cfg)

    def stats(self):
        data = self.request("stats")
        return normalise_stats(data)

    def top(self, count=20, family=None, sort="packets"):
        data = self.request("top", n=count, family=family, sort=sort)
        rows = data.get("sources") or data.get("top") or []
        return [normalise_top_row(r) for r in rows if isinstance(r, dict)]

    def list_entries(self, what, limit=0):
        data = self.request("list", what=what, limit=limit or None)
        rows = data.get("entries") or []
        return [r for r in rows if isinstance(r, dict)]

    def conntrack(self, limit=50, proto=None, src=None):
        data = self.request("conntrack", limit=limit, proto=proto, src=src)
        rows = data.get("flows") or data.get("entries") or []
        return [r for r in rows if isinstance(r, dict)]

    def port_rules(self, proto):
        data = self.request("ports", proto=proto)
        rows = data.get("ports") or data.get("entries") or []
        return [r for r in rows if isinstance(r, dict)]

    def icmp_policy(self, version):
        data = self.request("icmp", version=version)
        return data.get("types") or {}

    # --- writes ---
    def add_ban(self, net, ttl_ns, reason, permanent):
        return self.request("ban", cidr=str(net), ttl_ns=ttl_ns,
                            reason=reason, permanent=bool(permanent) or None)

    def del_ban(self, net):
        return self.request("unban", cidr=str(net))

    def add_rule(self, kind, net, tag=0, bypass_rate=True):
        cmd = {"allow": "allow", "block": "block", "local": "local"}[kind]
        return self.request(cmd, cidr=str(net), tag=tag or None,
                            bypass_rate=bool(bypass_rate) if kind == "allow"
                            else None)

    def del_rule(self, kind, net):
        cmd = {"allow": "unallow", "block": "unblock",
               "local": "unlocal"}[kind]
        return self.request(cmd, cidr=str(net))

    def set_mode(self, mode):
        return self.request("mode", mode=mode)

    def set_port(self, proto, first, last, action, rate, burst):
        return self.request("port", proto=proto, first=first, last=last,
                            action=action, rate=rate, burst=burst)

    def reload(self):
        return self.request("reload")

    def event_stream(self):
        if not hasattr(socket, "AF_UNIX"):
            return None
        try:
            sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
            sock.settimeout(self.timeout)
            sock.connect(self.path)
            payload = {"id": 1, "cmd": "subscribe",
                       "args": {"streams": ["events"]}}
            sock.sendall((json.dumps(payload) + "\n").encode("utf-8"))
            sock.setblocking(False)
        except (OSError, socket.error):
            return None
        return EventStream(sock)


def normalise_stats(data):
    """Accept name-keyed dicts, index-keyed dicts, or plain lists."""
    def to_vector(obj, names, index):
        vec = [0] * len(names)
        if isinstance(obj, list):
            for i, value in enumerate(obj):
                if i < len(vec):
                    try:
                        vec[i] = int(value)
                    except (TypeError, ValueError):
                        vec[i] = 0
            return vec
        if isinstance(obj, dict):
            for key, value in obj.items():
                idx = None
                if key in index:
                    idx = index[key]
                else:
                    try:
                        idx = int(key)
                    except (TypeError, ValueError):
                        idx = None
                if idx is None or not (0 <= idx < len(vec)):
                    continue
                try:
                    vec[idx] = int(value)
                except (TypeError, ValueError):
                    pass
        return vec

    packets = data.get("packets")
    if packets is None:
        packets = data.get("pkts")
    return {
        "ts_ns": int(data.get("ts_ns") or monotonic_ns()),
        "packets": to_vector(packets, STAT_NAMES, STAT_INDEX),
        "bytes": to_vector(data.get("bytes"), STAT_NAMES, STAT_INDEX),
        "gauges": to_vector(data.get("gauges"), GAUGE_NAMES, GAUGE_INDEX),
    }


def normalise_top_row(row):
    out = {
        "addr": str(row.get("addr") or row.get("address") or "?"),
        "family": int(row.get("family") or
                      (CALY_AF_INET6 if ":" in str(row.get("addr", ""))
                       else CALY_AF_INET)),
        "packets": int(row.get("packets") or 0),
        "bytes": int(row.get("bytes") or 0),
        "drops": int(row.get("drops") or 0),
        "drop_bytes": int(row.get("drop_bytes") or 0),
        "first_seen_ns": int(row.get("first_seen_ns") or 0),
        "last_seen_ns": int(row.get("last_seen_ns") or 0),
        "last_reason": row.get("last_reason") or 0,
    }
    if isinstance(out["last_reason"], str):
        out["last_reason"] = STAT_INDEX.get(out["last_reason"], 0)
    return out


# ---------------------------------------------------------------------------
# Direct backend - pinned maps via bpftool
# ---------------------------------------------------------------------------

def lpm_key(net):
    """LPM_TRIE key: prefixlen in HOST order, then address bytes, MSB first."""
    raw = net.network_address.packed
    width = 4 if net.version == 4 else 16
    return struct.pack("=I", int(net.prefixlen)) + raw.ljust(width, b"\0")


def lpm_key_decode(raw, version):
    width = 4 if version == 4 else 16
    if raw is None or len(raw) < 4 + width:
        return None
    prefixlen = struct.unpack_from("=I", raw, 0)[0]
    addr = raw[4:4 + width]
    if prefixlen > (32 if version == 4 else 128):
        return None
    try:
        text = "{0}/{1}".format(bytes_to_ip(addr, CALY_AF_INET
                                            if version == 4 else CALY_AF_INET6),
                                prefixlen)
        return ipaddress.ip_network(text, strict=False)
    except (ValueError, CalyError):
        return None


def host_key(addr):
    """Key of caly_ban4/rate4/scan4/top4 (__u32 network order) or the v6 form."""
    return addr.packed


class DirectBackend(Backend):
    name = "direct"

    def __init__(self, pin_dir=CALY_PIN_DIR, verbose=False, bpftool=None):
        self.pin_dir = pin_dir
        self.bt = bpftool or Bpftool(pin_dir, verbose=verbose)
        self.verbose = verbose
        if not os.path.isdir(pin_dir):
            raise BackendUnavailable(
                "no pinned maps under {0}. The dataplane is not loaded, or "
                "bpffs is not mounted (see: calyctl doctor).".format(pin_dir))
        self.bt.require()

    # --- config ---
    def _config_raw(self):
        entry = self.bt.map_lookup(MAP_CONFIG, struct.pack("=I", 0))
        if entry is None:
            raise CalyError("caly_config is empty; the dataplane has no "
                            "configuration loaded")
        value = entry.get("value") if isinstance(entry, dict) else None
        if value is None and isinstance(entry, dict):
            value = entry.get("values")
            if isinstance(value, list) and value:
                first = value[0]
                value = first.get("value") if isinstance(first, dict) else first
        raw = bt_bytes(value, SZ_FW_CONFIG)
        if raw is None and isinstance(value, dict):
            raise NotSupported(
                "bpftool rendered caly_config as a formatted structure; "
                "use the daemon backend for configuration reads")
        if raw is None or len(raw) < SZ_FW_CONFIG:
            raise CalyError("caly_config returned {0} bytes, expected "
                            "{1}".format(0 if raw is None else len(raw),
                                         SZ_FW_CONFIG))
        return raw[:SZ_FW_CONFIG]

    def config(self):
        return decode_fw_config(self._config_raw())

    def _write_config(self, raw):
        self.bt.map_update(MAP_CONFIG, struct.pack("=I", 0), raw)

    # --- reads ---
    def _counter_vector(self, map_name, length):
        vec = [0] * length
        try:
            entries = self.bt.map_dump(map_name)
        except BackendUnavailable:
            return vec
        for entry in entries:
            if not isinstance(entry, dict):
                continue
            idx = bt_u32(entry.get("key"))
            if 0 <= idx < length:
                vec[idx] = bt_percpu_sum(entry)
        return vec

    def stats(self):
        return {
            "ts_ns": monotonic_ns(),
            "packets": self._counter_vector(MAP_STATS, STAT_MAX),
            "bytes": self._counter_vector(MAP_STATS_B, STAT_MAX),
            "gauges": self._counter_vector(MAP_GLOBAL, GAUGE_MAX),
        }

    def _dump_src_stats(self, map_name, family, key_size):
        rows = []
        if not self.bt.has_map(map_name):
            return rows
        for entry in self.bt.map_dump(map_name):
            if not isinstance(entry, dict):
                continue
            key = coerce_addr_key(entry.get("key"), family)
            value = entry.get("value")
            if value is None:
                continue
            raw = bt_bytes(value, 56)
            stats = decode_src_stats(raw if raw is not None else value)
            addr = bytes_to_ip(key, family) if key else "?"
            stats["addr"] = addr
            stats["family"] = family
            rows.append(stats)
        return rows

    def top(self, count=20, family=None, sort="packets"):
        rows = []
        if family in (None, 4, CALY_AF_INET, "4", "inet"):
            rows += self._dump_src_stats(MAP_TOP4, CALY_AF_INET, 4)
        if family in (None, 6, CALY_AF_INET6, "6", "inet6"):
            rows += self._dump_src_stats(MAP_TOP6, CALY_AF_INET6, 16)
        key = sort if sort in ("packets", "bytes", "drops", "drop_bytes") \
            else "packets"
        rows.sort(key=lambda r: r.get(key, 0), reverse=True)
        return rows[:count] if count else rows

    def _dump_lpm(self, map_name, version, limit=0):
        rows = []
        if not self.bt.has_map(map_name):
            return rows
        try:
            entries = self.bt.map_dump(map_name)
        except CalyError as exc:
            raise CalyError(
                "{0}. Some kernels cannot enumerate LPM tries; use the "
                "daemon backend for listing.".format(exc.message))
        for entry in entries:
            if not isinstance(entry, dict):
                continue
            raw_key = coerce_lpm_key(entry.get("key"), version)
            net = lpm_key_decode(raw_key, version) if raw_key else None
            if net is None:
                continue
            raw_val = bt_bytes(entry.get("value"), 24)
            meta = decode_rule_meta(raw_val if raw_val is not None
                                    else entry.get("value") or {})
            meta["cidr"] = str(net)
            meta["family"] = version
            rows.append(meta)
            if limit and len(rows) >= limit:
                break
        return rows

    def _dump_bans(self, map_name, family, key_size, limit=0):
        rows = []
        if not self.bt.has_map(map_name):
            return rows
        for entry in self.bt.map_dump(map_name):
            if not isinstance(entry, dict):
                continue
            key = coerce_addr_key(entry.get("key"), family)
            if key is None:
                continue
            raw_val = bt_bytes(entry.get("value"), 64)
            ban = decode_ban_entry(raw_val if raw_val is not None
                                   else entry.get("value") or {})
            ban["cidr"] = "{0}/{1}".format(bytes_to_ip(key, family),
                                           32 if family == CALY_AF_INET else 128)
            ban["addr"] = bytes_to_ip(key, family)
            ban["family"] = 4 if family == CALY_AF_INET else 6
            rows.append(ban)
            if limit and len(rows) >= limit:
                break
        return rows

    def list_entries(self, what, limit=0):
        if what == "allow":
            return self._dump_lpm(MAP_ALLOW4, 4, limit) + \
                   self._dump_lpm(MAP_ALLOW6, 6, limit)
        if what == "block":
            return self._dump_lpm(MAP_BLOCK4, 4, limit) + \
                   self._dump_lpm(MAP_BLOCK6, 6, limit)
        if what == "local":
            return self._dump_lpm(MAP_LOCAL4, 4, limit) + \
                   self._dump_lpm(MAP_LOCAL6, 6, limit)
        if what in ("bans", "ban"):
            return self._dump_bans(MAP_BAN4, CALY_AF_INET, 4, limit) + \
                   self._dump_bans(MAP_BAN6, CALY_AF_INET6, 16, limit)
        raise CalyError("unknown list {0!r} "
                        "(allow, block, local, bans)".format(what))

    def conntrack(self, limit=50, proto=None, src=None):
        rows = []
        if not self.bt.has_map(MAP_CONN):
            return rows
        want_proto = None
        if proto:
            want_proto = PROTO_BY_NAME.get(str(proto).lower())
            if want_proto is None:
                try:
                    want_proto = int(proto)
                except (TypeError, ValueError):
                    raise CalyError("unknown protocol {0!r}".format(proto))
        want_src = parse_cidr(src) if src else None
        for entry in self.bt.map_dump(MAP_CONN):
            if not isinstance(entry, dict):
                continue
            raw_key = bt_bytes(entry.get("key"), SZ_CONN_KEY)
            key = decode_conn_key(raw_key if raw_key is not None
                                  else entry.get("key") or {})
            raw_val = bt_bytes(entry.get("value"), 64)
            state = decode_conn_state(raw_val if raw_val is not None
                                      else entry.get("value") or {})
            family = key["family"]
            row = dict(state)
            row["family"] = 4 if family == CALY_AF_INET else 6
            row["proto"] = key["proto"]
            row["saddr"] = bytes_to_ip(key["saddr"], family)
            row["daddr"] = bytes_to_ip(key["daddr"], family)
            row["sport"] = key["sport"]
            row["dport"] = key["dport"]
            if want_proto is not None and row["proto"] != want_proto:
                continue
            if want_src is not None:
                try:
                    addr = ipaddress.ip_address(row["saddr"])
                except ValueError:
                    continue
                if addr.version != want_src.version or addr not in want_src:
                    continue
            rows.append(row)
            if limit and len(rows) >= limit:
                break
        rows.sort(key=lambda r: r.get("last_seen_ns", 0), reverse=True)
        return rows

    def port_rules(self, proto):
        map_name = MAP_PORT_TCP if proto == "tcp" else MAP_PORT_UDP
        rows = []
        if not self.bt.has_map(map_name):
            return rows
        for entry in self.bt.map_dump(map_name):
            if not isinstance(entry, dict):
                continue
            port = bt_u32(entry.get("key"))
            raw_val = bt_bytes(entry.get("value"), 24)
            rule = decode_port_rule(raw_val if raw_val is not None
                                    else entry.get("value") or {})
            if rule["mode"] == 0 and rule["flags"] == 0 and \
                    rule["rate"] == 0 and rule["burst"] == 0:
                continue                     # untouched slot
            rule["port"] = port
            rule["proto"] = proto
            rows.append(rule)
        rows.sort(key=lambda r: r["port"])
        return rows

    def _port_rule(self, proto, port):
        map_name = MAP_PORT_TCP if proto == "tcp" else MAP_PORT_UDP
        entry = self.bt.map_lookup(map_name, struct.pack("=I", port))
        if not isinstance(entry, dict):
            return {"rate": 0, "burst": 0, "mode": 0, "flags": 0}
        raw = bt_bytes(entry.get("value"), 24)
        return decode_port_rule(raw if raw is not None
                                else entry.get("value") or {})

    def icmp_policy(self, version):
        map_name = MAP_ICMP4_POL if version == 4 else MAP_ICMP6_POL
        out = {}
        if not self.bt.has_map(map_name):
            return out
        for entry in self.bt.map_dump(map_name):
            if not isinstance(entry, dict):
                continue
            out[bt_u32(entry.get("key"))] = bt_u32(entry.get("value"))
        return out

    def _count_map(self, map_name, cap=100000):
        if not self.bt.has_map(map_name):
            return None
        try:
            entries = self.bt.map_dump(map_name)
        except CalyError:
            return None
        return min(len(entries), cap)

    def status(self, full=False):
        cfg = None
        cfg_error = None
        try:
            cfg = self.config()
        except CalyError as exc:
            cfg_error = exc.message
        ifaces = []
        if self.bt.has_map(MAP_IFACE):
            try:
                for entry in self.bt.map_dump(MAP_IFACE):
                    if not isinstance(entry, dict):
                        continue
                    ifindex = bt_u32(entry.get("key"))
                    raw = bt_bytes(entry.get("value"), 32)
                    if raw is not None:
                        flags, idx, zone = struct.unpack_from("=QII", raw, 0)
                    else:
                        value = entry.get("value") or {}
                        flags = _dget(value, "flags")
                        idx = _dget(value, "ifindex")
                        zone = _dget(value, "zone")
                    name = ifindex_to_name(ifindex or idx)
                    ifaces.append({"ifindex": ifindex or idx, "name": name,
                                   "zone": zone, "flags": flags})
            except CalyError:
                pass
        counts = {}
        if full:
            counts = {
                "bans": (self._count_map(MAP_BAN4) or 0) +
                        (self._count_map(MAP_BAN6) or 0),
                "allow": (self._count_map(MAP_ALLOW4) or 0) +
                         (self._count_map(MAP_ALLOW6) or 0),
                "block": (self._count_map(MAP_BLOCK4) or 0) +
                         (self._count_map(MAP_BLOCK6) or 0),
                "local": (self._count_map(MAP_LOCAL4) or 0) +
                         (self._count_map(MAP_LOCAL6) or 0),
                "conn": self._count_map(MAP_CONN) or 0,
            }
        attachments = read_xdp_attachments()
        return {
            "backend": "direct",
            "pin_dir": self.pin_dir,
            "bpftool": self.bt.path,
            "config": cfg,
            "config_error": cfg_error,
            "interfaces": ifaces,
            "attachments": attachments,
            "counts": counts,
            "maps": dict((n, self.bt.has_map(n)) for n in ALL_MAP_NAMES),
        }

    # --- writes ---
    def _require_root(self, what):
        if not is_root():
            raise CalyError("{0} needs root when talking to the maps "
                            "directly".format(what), EXIT_REFUSED)

    def add_ban(self, net, ttl_ns, reason, permanent):
        self._require_root("banning")
        now = monotonic_ns()
        if net.prefixlen not in (32 if net.version == 4 else 128,):
            # Only host addresses fit the ban LRU; a prefix has to live in the
            # static blocklist, where no TTL is enforced without the daemon.
            meta = {"added_ns": now, "hits": 0,
                    "flags": RULE_F_BLOCK, "tag": 0}
            map_name = MAP_BLOCK4 if net.version == 4 else MAP_BLOCK6
            self.bt.map_update(map_name, lpm_key(net), encode_rule_meta(meta))
            return {"changed": 1, "target": "blocklist",
                    "note": "prefix bans have no TTL without the daemon"}
        entry = {
            "expiry_ns": 0 if permanent else now + int(ttl_ns),
            "first_seen_ns": now,
            "last_hit_ns": 0,
            "cur_ttl_ns": 0 if permanent else int(ttl_ns),
            "hit_pkts": 0, "hit_bytes": 0,
            "reason": int(reason) if reason is not None else STAT_BAN_ADDED,
            "strikes": 0, "offences": 1,
            "flags": BAN_F_MANUAL | (BAN_F_PERMANENT if permanent else 0),
        }
        map_name = MAP_BAN4 if net.version == 4 else MAP_BAN6
        self.bt.map_update(map_name, host_key(net.network_address),
                           encode_ban_entry(entry))
        return {"changed": 1, "target": "ban"}

    def del_ban(self, net):
        self._require_root("unbanning")
        host_bits = 32 if net.version == 4 else 128
        if net.prefixlen != host_bits:
            map_name = MAP_BLOCK4 if net.version == 4 else MAP_BLOCK6
            gone = self.bt.map_delete(map_name, lpm_key(net))
            return {"changed": 1 if gone else 0, "target": "blocklist"}
        map_name = MAP_BAN4 if net.version == 4 else MAP_BAN6
        gone = self.bt.map_delete(map_name, host_key(net.network_address))
        return {"changed": 1 if gone else 0, "target": "ban"}

    _RULE_MAPS = {
        ("allow", 4): MAP_ALLOW4, ("allow", 6): MAP_ALLOW6,
        ("block", 4): MAP_BLOCK4, ("block", 6): MAP_BLOCK6,
        ("local", 4): MAP_LOCAL4, ("local", 6): MAP_LOCAL6,
    }
    _RULE_FLAGS = {"allow": RULE_F_ALLOW, "block": RULE_F_BLOCK,
                   "local": RULE_F_LOCAL}

    def add_rule(self, kind, net, tag=0, bypass_rate=True):
        self._require_root("editing lists")
        map_name = self._RULE_MAPS[(kind, net.version)]
        flags = self._RULE_FLAGS[kind]
        if kind == "allow" and bypass_rate:
            flags |= RULE_F_BYPASS_RATE
        meta = {"added_ns": monotonic_ns(), "hits": 0,
                "flags": flags, "tag": int(tag or 0)}
        self.bt.map_update(map_name, lpm_key(net), encode_rule_meta(meta))
        return {"changed": 1}

    def add_rules_bulk(self, kind, nets, tag=0, bypass_rate=True):
        self._require_root("editing lists")
        now = monotonic_ns()
        flags = self._RULE_FLAGS[kind]
        if kind == "allow" and bypass_rate:
            flags |= RULE_F_BYPASS_RATE
        value = encode_rule_meta({"added_ns": now, "hits": 0,
                                  "flags": flags, "tag": int(tag or 0)})
        done = 0
        for version in (4, 6):
            batch = [(lpm_key(n), value) for n in nets if n.version == version]
            if not batch:
                continue
            map_name = self._RULE_MAPS[(kind, version)]
            if len(batch) <= 4:
                for key, val in batch:
                    self.bt.map_update(map_name, key, val)
                done += len(batch)
            else:
                done += self.bt.batch_update(map_name, batch)
        return {"changed": done}

    def del_rule(self, kind, net):
        self._require_root("editing lists")
        map_name = self._RULE_MAPS[(kind, net.version)]
        gone = self.bt.map_delete(map_name, lpm_key(net))
        return {"changed": 1 if gone else 0}

    def set_mode(self, mode):
        self._require_root("changing mode")
        raw = self._config_raw()
        cfg = decode_fw_config(raw)
        enforce_mgmt_invariant(cfg)
        cfg["mode"] = int(mode)
        cfg["config_gen"] = cfg.get("config_gen", 0) + 1
        if int(mode) == 4:
            cfg["flags"] = cfg.get("flags", 0) | F_MONITOR_ONLY
        else:
            cfg["flags"] = cfg.get("flags", 0) & ~F_MONITOR_ONLY
        self._write_config(encode_fw_config(cfg, raw))
        return {"changed": 1, "mode": int(mode),
                "note": "written directly to caly_config; the daemon will "
                        "overwrite it on the next reload"}

    def set_port(self, proto, first, last, action, rate, burst):
        self._require_root("editing port policy")
        map_name = MAP_PORT_TCP if proto == "tcp" else MAP_PORT_UDP
        mode = {"open": 1, "close": 0, "closed": 0,
                "limit": 2, "ratelimit": 2}[action]
        pairs = []
        for port in range(first, last + 1):
            existing = self._port_rule(proto, port)
            rule = {
                "rate": int(rate) if rate is not None else existing["rate"],
                "burst": int(burst) if burst is not None else existing["burst"],
                "mode": mode,
                # Never clobber the amplifier / mgmt / synproxy flags: they are
                # policy the operator set elsewhere. Always mark the rule PRESENT
                # (matching maps.c) so an operator-set mode==CLOSED rule is not
                # byte-identical to a never-written all-zero slot; otherwise a
                # break-glass `port close` on a fresh port is a silent no-op.
                "flags": existing["flags"] | PORT_F_PRESENT,
            }
            if mode == 2 and (rule["rate"] == 0 or rule["burst"] == 0):
                raise CalyError(
                    "ratelimit needs --rate and --burst; a bucket with a zero "
                    "rate or burst is disabled and passes everything")
            pairs.append((struct.pack("=I", port), encode_port_rule(rule)))
        if len(pairs) <= 4:
            for key, value in pairs:
                self.bt.map_update(map_name, key, value)
        else:
            self.bt.batch_update(map_name, pairs)
        return {"changed": len(pairs)}

    def reload(self):
        raise NotSupported(
            "reload needs the daemon (try: systemctl reload calyanti)")


def enforce_mgmt_invariant(cfg):
    """TCP/22 must be in the management list. Refuse to write a config that
    would leave it out - the loader enforces this too, but the CLI must never
    be the thing that removes it."""
    ports = cfg.get("mgmt_tcp_ports") or []
    if 22 not in ports:
        raise CalyError(
            "refusing to write a configuration whose management TCP port "
            "list does not contain 22. That is the lockout invariant; fix "
            "mgmt_tcp_ports in {0} and reload.".format(CALY_CONF_PATH),
            EXIT_REFUSED)


