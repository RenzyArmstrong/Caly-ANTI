def _rule_add(opts, session, kind, verb):
    nets = [parse_cidr(c) for c in opts.cidr]
    what = ", ".join(str(n) for n in nets)
    if kind == "block":
        lockout_guard(nets, opts, "block", _mgmt_ports(session), opts.pal)
    if not confirm(opts, "{0} {1}?".format(verb.capitalize(), what),
                   default=(kind == "allow")):
        print("aborted")
        return EXIT_REFUSED
    changed = 0
    for net in nets:
        result = session.call("add_rule", kind, net, opts.tag,
                              not getattr(opts, "no_bypass_rate", False))
        changed += int(result.get("changed", 1) or 0)
    if opts.json:
        emit_json({kind: [str(n) for n in nets], "changed": changed})
        return EXIT_OK
    print("{0} {1} ({2} entr{3})".format(verb, what, changed,
                                         "y" if changed == 1 else "ies"))
    if kind == "allow":
        print("  note: an allowlist hit is an unconditional XDP_PASS. "
              "Keep the list short.")
    return EXIT_OK


def _rule_del(opts, session, kind, verb):
    nets = [parse_cidr(c) for c in opts.cidr]
    what = ", ".join(str(n) for n in nets)
    if kind == "allow":
        # Removing your own network from the allowlist is a lockout risk in
        # exactly the same way a ban is.
        lockout_guard(nets, opts, "remove from the allowlist",
                      _mgmt_ports(session), opts.pal)
    if not confirm(opts, "{0} {1}?".format(verb.capitalize(), what),
                   default=True):
        print("aborted")
        return EXIT_REFUSED
    changed = 0
    for net in nets:
        changed += int(session.call("del_rule", kind, net).get("changed", 0)
                       or 0)
    if opts.json:
        emit_json({"removed": [str(n) for n in nets], "list": kind,
                   "changed": changed})
        return EXIT_OK
    print("{0} {1} ({2} removed)".format(verb, what, changed))
    return EXIT_OK


