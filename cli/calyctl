def cmd_status(opts, session):
    info = session.call("status", full=not getattr(opts, "fast", False))
    cfg = info.get("config")
    if isinstance(cfg, dict):
        cfg = normalise_config(cfg)
        info["config"] = cfg

    rates = None
    if not getattr(opts, "fast", False):
        try:
            first = session.call("stats")
            time.sleep(0.5)
            second = session.call("stats")
            dt = max(1e-6, (second["ts_ns"] - first["ts_ns"]) / 1e9)
            rates = {}
            for i, name in enumerate(GAUGE_NAMES):
                rates[name] = rate_of(second["gauges"][i],
                                      first["gauges"][i], dt)
            info["rates"] = rates
            info["totals"] = dict(
                (n, second["gauges"][i]) for i, n in enumerate(GAUGE_NAMES))
        except CalyError:
            rates = None

    if opts.json:
        info["backend"] = session.describe()
        emit_json(info)
        return EXIT_OK

    pal = opts.pal
    print(pal.paint("Caly Anti", "bcyan") + "   calyctl " + CALYCTL_VERSION)
    print_kv("backend", session.describe(), pal)
    if info.get("version"):
        detail = "version {0}".format(info["version"])
        if info.get("pid"):
            detail += ", pid {0}".format(info["pid"])
        if info.get("uptime_ns"):
            detail += ", up {0}".format(human_ns(info["uptime_ns"]))
        print_kv("daemon", detail, pal)
    if info.get("config_error"):
        print_kv("config", pal.paint(info["config_error"], "red"), pal)

    if isinstance(cfg, dict):
        mode = int(cfg.get("mode", 0))
        flags = int(cfg.get("flags", 0))
        abi = int(cfg.get("abi_version", 0))
        mode_text = MODE_NAMES.get(mode, "?").upper()
        if flags & F_MONITOR_ONLY and mode != 4:
            mode_text += " (monitor-only)"
        print_kv("mode", pal.paint(mode_text, mode_colour(mode)), pal)
        enabled = "yes" if flags & F_ENABLED else "NO - dataplane is passive"
        print_kv("enabled", pal.paint(
            enabled, "green" if flags & F_ENABLED else "bred"), pal)
        print_kv("abi", "{0}.{1}{2}".format(
            abi >> 16, abi & 0xFFFF,
            "" if (abi >> 16) == CALY_ABI_VERSION_MAJOR
            else pal.paint("  MAJOR MISMATCH with calyctl {0}.{1}".format(
                CALY_ABI_VERSION_MAJOR, CALY_ABI_VERSION_MINOR), "bred")), pal)
        print_kv("config gen", cfg.get("config_gen", 0), pal)
        print_kv("dataplane", "{0} / attach {1}".format(
            DATAPLANE_NAMES.get(int(cfg.get("dataplane_pref", 0)), "?"),
            XDP_MODE_NAMES.get(int(cfg.get("xdp_attach_pref", 0)), "?")), pal)
        policy = [n for b, n in FW_FLAG_BITS if b < 32 and flags & (1 << b)]
        caps = [n[4:] for b, n in FW_FLAG_BITS if b >= 32 and flags & (1 << b)]
        print_kv("policy", ", ".join(policy) or "-", pal)
        print_kv("capabilities", ", ".join(caps) or "-", pal)
        tcp_ports = cfg.get("mgmt_tcp_ports") or []
        udp_ports = cfg.get("mgmt_udp_ports") or []
        mgmt = "tcp {0}".format(",".join(str(p) for p in tcp_ports) or "-")
        mgmt += "   udp {0}".format(",".join(str(p) for p in udp_ports) or "-")
        if 22 not in tcp_ports:
            mgmt += pal.paint("   [!] TCP/22 MISSING - lockout risk", "bred")
        print_kv("management", mgmt, pal)
        buckets = []
        for i, name in enumerate(TB_NAMES):
            rate = cfg["tb_rate"][i] if i < len(cfg.get("tb_rate", [])) else 0
            burst = cfg["tb_burst"][i] if i < len(cfg.get("tb_burst", [])) else 0
            if not rate or not burst:
                buckets.append("{0}=off".format(name))
            else:
                buckets.append("{0}={1}/{2}".format(
                    name, human_count(rate), human_count(burst)))
        print_kv("src buckets", "  ".join(buckets), pal)

    ifaces = info.get("interfaces") or []
    attachments = info.get("attachments") or read_xdp_attachments()
    if ifaces or attachments:
        print()
        rows = []
        seen = set()
        for iface in ifaces:
            name = iface.get("name") or ifindex_to_name(iface.get("ifindex"))
            seen.add(name)
            att = attachments.get(name) or {}
            rows.append((name, iface.get("ifindex", "-"),
                         ZONE_NAMES.get(int(iface.get("zone", 0)), "?"),
                         flags_str(iface.get("flags", 0), IFACE_FLAG_BITS),
                         att.get("mode", "-"),
                         att.get("prog_name") or (
                             "id {0}".format(att["prog_id"])
                             if att.get("prog_id") else "-")))
        for name, att in sorted(attachments.items()):
            if name in seen:
                continue
            rows.append((name, "-", "default", "-", att.get("mode", "-"),
                         att.get("prog_name") or (
                             "id {0}".format(att["prog_id"])
                             if att.get("prog_id") else "-")))
        print_table(rows, ("interface", "idx", "zone", "flags",
                           "xdp", "program"),
                    ["l", "r", "l", "l", "l", "l"], pal)

    counts = info.get("counts") or {}
    if counts:
        print()
        print_kv("bans", counts.get("bans", "-"), pal)
        print_kv("allowlist", counts.get("allow", "-"), pal)
        print_kv("blocklist", counts.get("block", "-"), pal)
        print_kv("conntrack", counts.get("conn", "-"), pal)

    if rates:
        print()
        print_kv("packets/s", human_count(rates.get("pkts", 0)), pal)
        print_kv("bytes/s", "{0}  ({1})".format(
            human_bps(rates.get("bytes", 0)),
            human_bits(rates.get("bytes", 0))), pal)
        drop_rate = rates.get("drops", 0)
        print_kv("drops/s", pal.paint(
            human_count(drop_rate), "red" if drop_rate > 0 else None), pal)
        print_kv("syn/s", human_count(rates.get("syn", 0)), pal)
        print_kv("newconn/s", human_count(rates.get("newconn", 0)), pal)
        lost = info.get("totals", {}).get("events_lost", 0)
        if lost:
            print_kv("events lost", pal.paint(str(lost), "yellow"), pal)
    return EXIT_OK


