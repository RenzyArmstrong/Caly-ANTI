def cmd_top(opts, session):
    rows = session.call("top", count=opts.n, family=opts.family,
                        sort=opts.sort)
    if opts.json:
        emit_json({"sources": rows})
        return EXIT_OK
    if not rows:
        print("no source statistics recorded "
              "(src_stats disabled, or no traffic yet)")
        return EXIT_OK
    now_mono, now_wall = monotonic_ns(), time.time()
    pal = opts.pal
    table = []
    for i, row in enumerate(rows, 1):
        pkts = row.get("packets", 0)
        drops = row.get("drops", 0)
        pct = (100.0 * drops / pkts) if pkts else 0.0
        table.append((
            i, row.get("addr", "?"),
            human_count(pkts), human_bytes(row.get("bytes", 0)),
            human_count(drops), "{0:.1f}%".format(pct),
            reason_name(row.get("last_reason", 0)),
            fmt_time(row.get("last_seen_ns", 0), now_mono, now_wall),
        ))
    print_table(table, ("#", "source", "packets", "bytes", "drops",
                        "drop%", "last reason", "last seen"),
                ["r", "l", "r", "r", "r", "r", "l", "l"], pal)
    return EXIT_OK


