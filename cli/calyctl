def emit_json(obj):
    json.dump(obj, sys.stdout, indent=2, sort_keys=True, default=str)
    sys.stdout.write("\n")


def print_table(rows, headers, aligns=None, pal=None, indent="  "):
    """Column-aligned table. rows is a list of tuples of already-formatted
    strings."""
    pal = pal or Palette(False)
    if not rows:
        return
    ncols = len(headers)
    aligns = aligns or ["l"] * ncols
    widths = [len(str(h)) for h in headers]
    for row in rows:
        for i in range(ncols):
            widths[i] = max(widths[i], len(str(row[i])) if i < len(row) else 0)
    max_w = term_size()[0] - len(indent)
    total = sum(widths) + 2 * (ncols - 1)
    if total > max_w and ncols > 1:
        # Shrink the widest column first; never below 8 characters.
        over = total - max_w
        order = sorted(range(ncols), key=lambda i: widths[i], reverse=True)
        for i in order:
            if over <= 0:
                break
            room = max(0, widths[i] - 8)
            take = min(room, over)
            widths[i] -= take
            over -= take

    def fmt(cells, bold=False):
        parts = []
        for i in range(ncols):
            text = truncate(str(cells[i]) if i < len(cells) else "", widths[i])
            parts.append(text.rjust(widths[i]) if aligns[i] == "r"
                         else text.ljust(widths[i]))
        line = indent + "  ".join(parts).rstrip()
        return pal.paint(line, "bold") if bold else line

    print(fmt(headers, bold=True))
    for row in rows:
        print(fmt(row))


def print_kv(key, value, pal=None, colour=None, width=15):
    pal = pal or Palette(False)
    label = str(key).ljust(width)
    text = str(value)
    print("{0}{1}".format(pal.paint(label, "bold") if pal.enabled else label,
                          pal.paint(text, colour) if colour else text))


def mode_colour(mode):
    return {0: "green", 1: "yellow", 2: "bred",
            3: "magenta", 4: "cyan"}.get(int(mode or 0), "white")


def rate_of(cur, prev, dt):
    if dt <= 0 or prev is None:
        return 0.0
    delta = cur - prev
    if delta < 0:                       # counters were reset
        return 0.0
    return delta / dt


