# SPDX-License-Identifier: BSD-2-Clause OR GPL-2.0
#
# Caly Anti - XDP/eBPF DDoS mitigation suite
# cli/calyctl - operator CLI and live TUI dashboard.
#
# Python 3.6+ (RHEL 8 ships 3.6). STDLIB ONLY: no pip, no third-party modules.
# curses is optional; every view degrades to plain text when curses or a TTY is
# unavailable.
#
# ----------------------------------------------------------------------------
# TWO BACKENDS
#
#   daemon   the normal path. A newline-delimited JSON request/response
#            protocol over the unix control socket owned by the
#            user/telemetry component (default /run/calyanti/control.sock).
#
#   direct   the break-glass path, used with --direct or automatically when
#            the socket is absent. Reads (and, where safe, writes) the pinned
#            maps under /sys/fs/bpf/calyanti via bpftool. Requires root.
#            Everything the dataplane owns is readable this way, so the CLI
#            keeps working when the daemon is dead - which is exactly when an
#            operator needs it most.
#
# ----------------------------------------------------------------------------
# CONTROL PROTOCOL (what this CLI speaks; the daemon must implement it)
#
#   Transport : SOCK_STREAM unix socket, mode 0660, root:calyanti.
#   Framing   : one UTF-8 JSON object per line, terminated by '\n'. No
#               embedded newlines. Lines longer than 8 MiB are a protocol
#               error and the connection is closed.
#
#   Request   : {"id": <int>, "cmd": "<name>", "args": {...}}
#   Response  : {"id": <int>, "ok": true,  "data": {...}}
#               {"id": <int>, "ok": false, "error": "<human text>",
#                "code": "<machine token>"}
#
#   The daemon MUST answer every request with exactly one response line, and
#   MUST echo the request id. Unknown commands answer ok=false with
#   code="unknown_command"; the CLI degrades to the direct backend for reads
#   when it sees that, so adding a command later is never a flag day.
#
#   Commands used by this CLI (all args optional unless marked *):
#
#     ping        -> {}
#     status      -> {version, pid, uptime_ns, dataplane, xdp_mode,
#                     interfaces:[{name,ifindex,zone,flags,attached,mode}],
#                     config:{...fw_config fields by C name...},
#                     counts:{bans,allow,block,local,conn,rate,scan}}
#     stats       -> {ts_ns, packets:{<reason>:<u64>}, bytes:{...},
#                     gauges:{<gauge>:<u64>}}
#                    Reason/gauge keys may be the enum name or the numeric
#                    index; both are accepted. Lists indexed by enum value are
#                    accepted too.
#     top         args {n, family, sort}
#                 -> {sources:[{addr,family,packets,bytes,drops,drop_bytes,
#                               first_seen_ns,last_seen_ns,last_reason}]}
#     list        args {what: allow|block|local|bans}*
#                 -> {entries:[{cidr,flags,tag,added_ns,hits,...}]}
#     ban         args {cidr*, ttl_ns, reason, permanent, force}
#     unban       args {cidr*}
#     allow       args {cidr*, tag, bypass_rate}
#     unallow     args {cidr*}
#     block       args {cidr*, tag}
#     unblock     args {cidr*}
#     mode        args {mode*}            mode is the enum fw_mode integer
#     port        args {proto*, first*, last*, action*, rate, burst}
#     conntrack   args {limit, proto, src}
#                 -> {flows:[{family,proto,saddr,sport,daddr,dport,state,
#                             flags,pkts_in,bytes_in,pkts_out,bytes_out,
#                             created_ns,last_seen_ns,ifindex}]}
#     reload      -> {config_gen}
#     subscribe   args {streams:["events"]}
#                 -> {streams:[...]} then an unsolicited line per event:
#                    {"stream":"events","event":{...struct event by name...}}
#
#   Every mutating command is idempotent and returns {"changed": <int>}.
#
# ----------------------------------------------------------------------------
# SAFETY
#
#   Destructive actions confirm on a TTY unless --yes, and refuse outright
#   when stdin is not a TTY and --yes was not given.
#
#   Banning or blocking a prefix that contains the address of the SSH session
#   running this command - or any address currently connected to a management
#   port - requires --force and prints a loud warning first. Removing such a
#   prefix from the allowlist is treated the same way. Banning a default route
#   (0.0.0.0/0 or ::/0) is refused unconditionally.
# ----------------------------------------------------------------------------

