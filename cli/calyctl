def stats_to_named(sample):
    return {
        "ts_ns": sample["ts_ns"],
        "packets": dict((STAT_NAMES[i], v)
                        for i, v in enumerate(sample["packets"]) if v),
        "bytes": dict((STAT_NAMES[i], v)
                      for i, v in enumerate(sample["bytes"]) if v),
        "gauges": dict((GAUGE_NAMES[i], v)
                       for i, v in enumerate(sample["gauges"])),
    }


def cmd_stats(opts, session):
    if opts.watch:
        return run_watch(opts, session)
    sample = session.call("stats")
    if opts.json:
        emit_json(stats_to_named(sample))
        return EXIT_OK

    pal = opts.pal
    pkts, byts = sample["packets"], sample["bytes"]
    print(pal.paint("aggregates", "bcyan"))
    rows = []
    for idx in (STAT_PKT_TOTAL, STAT_PASS_TOTAL, STAT_DROP_TOTAL,
                STAT_TX_TOTAL, STAT_MONITOR_WOULD_DROP):
        rows.append((STAT_NAMES[idx], human_count(pkts[idx]),
                     human_bytes(byts[idx])))
    total = pkts[STAT_PKT_TOTAL] or 1
    rows.append(("drop ratio", "{0:.3f}%".format(
        100.0 * pkts[STAT_DROP_TOTAL] / total), ""))
    print_table(rows, ("counter", "packets", "bytes"), ["l", "r", "r"], pal)

    def section(title, indices, colour=None):
        body = [(STAT_NAMES[i], human_count(pkts[i]), human_bytes(byts[i]))
                for i in indices if opts.all or pkts[i] or byts[i]]
        if not body:
            return
        print()
        print(pal.paint(title, colour or "bcyan"))
        if opts.sort == "value":
            body.sort(key=lambda r: -pkts[STAT_INDEX[r[0]]])
        print_table(body, ("reason", "packets", "bytes"),
                    ["l", "r", "r"], pal)

    drops = [i for i in range(STAT_MAX) if stat_is_drop(i)]
    passes = [i for i in range(5, STAT_DROP_ETH_TRUNC)]
    other = [i for i in range(STAT_MAX)
             if i not in drops and i not in passes and i > STAT_MONITOR_WOULD_DROP]
    section("drops", drops, "bred")
    section("passes", passes, "bgreen")
    section("machinery", other)

    print()
    print(pal.paint("gauges", "bcyan"))
    grows = []
    for i, name in enumerate(GAUGE_NAMES):
        value = sample["gauges"][i]
        grows.append((name, human_count(value),
                      human_bytes(value) if name == "bytes" else ""))
    print_table(grows, ("gauge", "value", ""), ["l", "r", "r"], pal)
    return EXIT_OK


