def ifindex_to_name(ifindex):
    try:
        if ifindex and hasattr(socket, "if_indextoname"):
            return socket.if_indextoname(int(ifindex))
    except (OSError, ValueError, TypeError):
        pass
    return "if{0}".format(ifindex)


def list_interfaces():
    out = []
    try:
        names = sorted(os.listdir("/sys/class/net"))
    except OSError:
        return out
    for name in names:
        base = os.path.join("/sys/class/net", name)
        driver = None
        try:
            link = os.path.join(base, "device", "driver")
            if os.path.islink(link):
                driver = os.path.basename(os.readlink(link))
        except OSError:
            driver = None
        out.append({
            "name": name,
            "ifindex": read_int_file(os.path.join(base, "ifindex"), 0),
            "operstate": (read_file(os.path.join(base, "operstate"), 32)
                          or "unknown").strip(),
            "mtu": read_int_file(os.path.join(base, "mtu"), 0),
            "driver": driver or "-",
        })
    return out


def read_xdp_attachments():
    """{ifname: {"mode": str, "prog_id": int}} for every attached XDP prog."""
    result = {}
    ip_bin = which("ip")
    if not ip_bin:
        return result
    rc, out, _ = run_cmd([ip_bin, "-details", "-json", "link", "show"])
    if rc == 0 and out.strip():
        try:
            links = json.loads(out)
        except ValueError:
            links = []
        for link in links if isinstance(links, list) else []:
            if not isinstance(link, dict):
                continue
            xdp = link.get("xdp")
            if not isinstance(xdp, dict):
                continue
            prog = xdp.get("prog") if isinstance(xdp.get("prog"), dict) else {}
            mode = xdp.get("mode")
            mode_name = {1: "native", 2: "generic", 3: "offload"}.get(
                mode, str(mode))
            result[link.get("ifname", "?")] = {
                "mode": mode_name,
                "prog_id": prog.get("id"),
                "prog_name": prog.get("name"),
                "tag": prog.get("tag"),
            }
        return result
    # Text fallback for iproute2 without JSON support.
    rc, out, _ = run_cmd([ip_bin, "-details", "link", "show"])
    if rc != 0:
        return result
    current = None
    for line in out.splitlines():
        match = re.match(r"^\d+:\s+([^:@]+)[:@]", line)
        if match:
            current = match.group(1).strip()
            continue
        if current and "xdp" in line:
            idm = re.search(r"prog/xdp id (\d+)", line)
            mode = "generic" if "xdpgeneric" in line else (
                "offload" if "xdpoffload" in line else "native")
            result[current] = {"mode": mode,
                               "prog_id": int(idm.group(1)) if idm else None,
                               "prog_name": None, "tag": None}
    return result


def kernel_release():
    try:
        return os.uname()[2]
    except Exception:
        return "unknown"


def kernel_version_tuple():
    rel = kernel_release()
    match = re.match(r"^(\d+)\.(\d+)(?:\.(\d+))?", rel)
    if not match:
        return (0, 0, 0)
    return (int(match.group(1)), int(match.group(2)),
            int(match.group(3) or 0))


def sysctl_get(name):
    path = "/proc/sys/" + name.replace(".", "/")
    value = read_file(path, 256)
    return value.strip() if value is not None else None


def bpffs_mounted(path=CALY_BPFFS_ROOT):
    mounts = read_file("/proc/mounts", 1 << 18) or ""
    for line in mounts.splitlines():
        fields = line.split()
        if len(fields) >= 3 and fields[1] == path and fields[2] == "bpf":
            return True
    return False


def detect_virt():
    binary = which("systemd-detect-virt")
    if binary:
        rc, out, _ = run_cmd([binary])
        text = out.strip()
        if rc == 0 and text:
            return text
        if text in ("none", ""):
            return "none"
    if os.path.exists("/proc/user_beancounters"):
        return "openvz"
    environ = read_file("/proc/1/environ", 8192) or ""
    if "container=lxc" in environ:
        return "lxc"
    if "container=docker" in environ:
        return "docker"
    if os.path.exists("/.dockerenv"):
        return "docker"
    return "none"


