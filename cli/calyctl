def cmd_port(opts, session):
    proto, first, last = parse_portspec(opts.portspec)
    action = opts.action
    rate = parse_scaled(opts.rate, "rate") if opts.rate else None
    burst = parse_scaled(opts.burst, "burst") if opts.burst else None
    if action == "limit" and (rate is None or burst is None):
        raise CalyError("limit needs --rate and --burst "
                        "(a bucket with rate or burst 0 is disabled)")
    mgmt = _mgmt_ports(session)
    if action == "close" and proto == "tcp":
        clash = [p for p in range(first, last + 1) if p in mgmt]
        if clash:
            print(opts.pal.paint(
                "  note: TCP {0} {1} also a management port; management "
                "ports are checked before port policy, so closing it here "
                "does not lock you out.".format(
                    ",".join(str(c) for c in clash),
                    "is" if len(clash) == 1 else "are"), "yellow"))
    span = "{0}/{1}".format(proto, first if first == last
                            else "{0}-{1}".format(first, last))
    count = last - first + 1
    detail = span if count == 1 else "{0} ({1} ports)".format(span, count)
    if not confirm(opts, "Set {0} to {1}?".format(detail, action)):
        print("aborted")
        return EXIT_REFUSED
    result = session.call("set_port", proto, first, last, action, rate, burst)
    if opts.json:
        result.setdefault("proto", proto)
        result.setdefault("first", first)
        result.setdefault("last", last)
        result.setdefault("action", action)
        emit_json(result)
        return EXIT_OK
    print("{0} -> {1}{2} ({3} entries)".format(
        detail, PORT_MODE_NAMES.get({"open": 1, "close": 0,
                                     "limit": 2}[action], action),
        "" if action != "limit" else " rate={0} burst={1}".format(rate, burst),
        result.get("changed", count)))
    return EXIT_OK


