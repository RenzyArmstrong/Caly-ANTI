def cmd_list(opts, session):
    what = opts.what
    if what == "ban":
        what = "bans"
    rows = session.call("list_entries", what, limit=opts.limit)
    if opts.json:
        emit_json({"what": what, "entries": rows})
        return EXIT_OK
    if not rows:
        print("({0} list is empty)".format(what))
        return EXIT_OK
    now_mono, now_wall = monotonic_ns(), time.time()
    pal = opts.pal
    if what == "bans":
        table = []
        for row in rows:
            expiry = int(row.get("expiry_ns", 0) or 0)
            flags = int(row.get("flags", 0) or 0)
            if flags & BAN_F_PERMANENT or expiry == 0:
                remaining = "permanent"
            else:
                left = expiry - now_mono
                remaining = human_ns(left) if left > 0 else \
                    pal.paint("expired", "dim")
            table.append((
                row.get("cidr") or row.get("addr", "?"),
                remaining,
                human_ns(row.get("cur_ttl_ns", 0)),
                reason_name(row.get("reason", 0)),
                row.get("offences", 0),
                human_count(row.get("hit_pkts", 0)),
                flags_str(flags, BAN_FLAG_BITS),
                fmt_time(row.get("first_seen_ns", 0), now_mono, now_wall),
            ))
        print_table(table, ("address", "expires in", "ttl", "reason",
                            "offences", "hits", "flags", "first seen"),
                    ["l", "r", "r", "l", "r", "r", "l", "l"], pal)
    else:
        table = []
        for row in rows:
            table.append((
                row.get("cidr", "?"),
                flags_str(row.get("flags", 0), RULE_FLAG_BITS),
                row.get("tag", 0),
                human_count(row.get("hits", 0)),
                fmt_time(row.get("added_ns", 0), now_mono, now_wall)
                if row.get("added_ns") else "boot config",
            ))
        print_table(table, ("prefix", "flags", "tag", "hits", "added"),
                    ["l", "l", "r", "r", "l"], pal)
    print()
    print("  {0} entr{1}".format(len(rows), "y" if len(rows) == 1 else "ies"))
