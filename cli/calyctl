class Palette(object):
    """ANSI colours, or empty strings when colour is off."""

    NAMES = ("reset", "bold", "dim", "red", "green", "yellow", "blue",
             "magenta", "cyan", "white", "bred", "bgreen", "byellow", "bcyan")
    CODES = {
        "reset": "\033[0m", "bold": "\033[1m", "dim": "\033[2m",
        "red": "\033[31m", "green": "\033[32m", "yellow": "\033[33m",
        "blue": "\033[34m", "magenta": "\033[35m", "cyan": "\033[36m",
        "white": "\033[37m", "bred": "\033[1;31m", "bgreen": "\033[1;32m",
        "byellow": "\033[1;33m", "bcyan": "\033[1;36m",
    }

    def __init__(self, enabled):
        self.enabled = bool(enabled)
        for name in self.NAMES:
            setattr(self, name, self.CODES[name] if self.enabled else "")

    def paint(self, text, colour):
        if not self.enabled:
            return text
        return "{0}{1}{2}".format(self.CODES.get(colour, ""), text,
                                  self.CODES["reset"])


def want_colour(choice, stream):
    if choice == "always":
        return True
    if choice == "never":
        return False
    if os.environ.get("NO_COLOR") is not None:
        return False
    if os.environ.get("TERM", "") in ("", "dumb"):
        return False
    try:
        return stream.isatty()
    except Exception:
        return False


def term_size(default=(80, 24)):
    try:
        import shutil
        size = shutil.get_terminal_size(default)
        return max(20, size.columns), max(6, size.lines)
    except Exception:
        return default


def unicode_ok():
    enc = (getattr(sys.stdout, "encoding", None) or "").lower()
    if "utf" in enc:
        return True
    for var in ("LC_ALL", "LC_CTYPE", "LANG"):
        val = os.environ.get(var, "")
        if "utf" in val.lower():
            return True
    return False


